    function mostrarSucesso(titulo, desc) {
      document.getElementById('cadastroInicio').style.display = 'none';
      document.getElementById('cadastroCarregando').style.display = 'none';
      document.getElementById('cadastroSucesso').style.display = 'block';
      document.getElementById('sucessoTitulo').textContent = titulo;
      document.getElementById('sucessoDesc').textContent = desc;
    }

    function mostrarErro(msg) {
      document.getElementById('cadastroInicio').style.display = 'block';
      document.getElementById('cadastroCarregando').style.display = 'none';
      document.getElementById('cadastroSucesso').style.display = 'none';
      const el = document.getElementById('cadastroError');
      el.textContent = msg;
      el.style.display = 'block';
    }

    async function loginGoogle() {
      mostrarCarregando('Redirecionando para o Google…');
      const sb = await initSupabase();
      const { error } = await sb.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: 'https://unilix.tech/callback.html', queryParams: { prompt: 'select_account', access_type: 'offline' } }
      });
      if (error) mostrarErro('Erro ao conectar com Google: ' + error.message);
