    async function submitForm() {
      const email = document.getElementById('inputEmail').value.trim();
      const senha = document.getElementById('inputSenha').value;
      const errorEl = document.getElementById('cadastroError');
      errorEl.style.display = 'none';

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        mostrarErro('Informe um e-mail válido.'); return;
      }
      if (!senha || senha.length < 6) {
        mostrarErro('A senha deve ter pelo menos 6 caracteres.'); return;
      }

      const sb = await initSupabase();

      if (abaAtual === 'cadastro') {
        const nome     = document.getElementById('inputNome').value.trim();
        const telefone = document.getElementById('inputTelefone').value.trim();
        if (!nome) { mostrarErro('Informe seu nome.'); return; }

        mostrarCarregando('Criando sua conta…');
        const { data, error } = await sb.auth.signUp({
          email, password: senha,
          options: { data: { full_name: nome, phone: telefone } }
        });
        if (error) { mostrarErro(error.message); return; }

        // Salva perfil extra na tabela profiles (crie no Supabase se não existir)
        if (data.user) {
          await sb.from('profiles').upsert({
            id: data.user.id, full_name: nome, phone: telefone, plan: 'free'
          });
        }
        mostrarCarregando('Preparando seu espaço…');
        try {
          await fetch('https://api.unilix.tech/criar-cliente', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nome, email, plano: 'free' })
          });
        } catch(e) { console.error('provisioning:', e); }
        mostrarSucesso('Tudo pronto! 🎉', 'Enviamos seu link de acesso e senha para ' + email + '. Verifique também o spam.');

      } else {
        mostrarCarregando('Entrando…');
        const { error } = await sb.auth.signInWithPassword({ email, password: senha });
        if (error) { mostrarErro('E-mail ou senha incorretos.'); return; }
        mostrarSucesso('Bem-vindo de volta! ✅', 'Login realizado com sucesso. Redirecionando…');
        setTimeout(() => { window.location.href = 'https://unilix.tech'; }, 2000);
      }
    }

    // Verifica sessão ativa — mostra banner, não redireciona forçado
    (async () => {
      try {
        const sb = await initSupabase();
        const { data: { session } } = await sb.auth.getSession();
        if (!session) return;
        const email = session.user.email;
