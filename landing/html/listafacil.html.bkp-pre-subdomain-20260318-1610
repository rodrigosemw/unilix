        tabL.style.background = 'var(--primary)';
        tabL.style.color = '#fff';
        tabC.style.background = 'transparent';
        tabC.style.color = 'var(--text-muted)';
        camposExtras.style.display = 'none';
        btnSubmit.textContent = 'Entrar';
