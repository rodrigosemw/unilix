async function toggleCheck(subId, itemId) {
  if (!_curSub || _curSub.status === 'concluida') return;
  if (!_curSub.checkedState) _curSub.checkedState = {};
  if (!_curSub.checkedNames) _curSub.checkedNames = {};
  const nowChecked = !_curSub.checkedState[itemId];
  _curSub.checkedState[itemId] = nowChecked;
  _curSub.checkedNames[itemId] = { name: CU.nome, by: CU.login };
  renderDetailItems();
  const upsertPayload = {submission_id:subId,item_id:itemId,checked:nowChecked,checked_by:CU.login,checked_name:CU.nome,updated_at:new Date().toISOString()};
  try {
    const res = await sbWrite({table:'checked_items',action:'upsert',payload:upsertPayload,conflict:'submission_id,item_id'});
    if (res.error) throw res.error;
    if (!_isOnline) toast('Salvo localmente — sincronizará ao reconectar','info');
  } catch(e) {
    _curSub.checkedState[itemId] = !nowChecked; renderDetailItems(); toast('Erro ao salvar','error'); return;
  }
  // Propagar para lista m\u00E3e e listas irm\u00E3s (repasses da mesma origem)
  // CORREÇÃO: s\u00F3 propaga se o item_id existir na lista de destino
  try {
    const parentId = _curSub.parent_id || null;
    const propagateIds = [];
    if (parentId) {
      propagateIds.push(parentId);
      const {data:siblings} = await sb.from('list_submissions').select('id,items').eq('parent_id',parentId).neq('id',subId);
      (siblings||[]).filter(s=>(s.items||[]).some(i=>String(i.id)===String(itemId))).forEach(s=>propagateIds.push(s.id));
    } else {
      const {data:children} = await sb.from('list_submissions').select('id,items').eq('parent_id',subId);
      (children||[]).filter(c=>(c.items||[]).some(i=>String(i.id)===String(itemId))).forEach(c=>propagateIds.push(c.id));
    }
    for (const pid of propagateIds) {
      await sbWrite({table:'checked_items',action:'upsert',payload:{...upsertPayload,submission_id:pid},conflict:'submission_id,item_id'});
    }
  } catch(e) { /* sync falhou silenciosamente */ }
  const items = _curSub.items||[];
  const allChecked = items.length > 0 && items.every(i=>!!_curSub.checkedState[i.id]);
  if (allChecked && document.getElementById('checkoutBtnWrap')) {
    const btnWrap = document.getElementById('checkoutBtnWrap');
    if(btnWrap.style.bottom !== '0px') {
       btnWrap.style.display = 'block';
       document.getElementById('ldBottomBar').style.display = 'none';
       setTimeout(() => { btnWrap.style.bottom = '0px'; }, 50);
    }
  } else if (!allChecked && document.getElementById('checkoutBtnWrap')) {
    const btnWrap = document.getElementById('checkoutBtnWrap');
    if(btnWrap.style.bottom === '0px') {
       btnWrap.style.bottom = '-200px';
       setTimeout(() => { 
         const bb=document.getElementById('ldBottomBar'); 
         if(bb) bb.style.display=''; 
       }, 400);
    }
  }
}

function setupSubRealtime(subId) {
  if (window._subRt) { try { sb.removeChannel(window._subRt); } catch(e){} window._subRt=null; }
  if (window._rtHeartbeat) { clearInterval(window._rtHeartbeat); window._rtHeartbeat=null; }
  let _lastRtEvent = Date.now();
  try {
    window._subRt = sb.channel('lf-'+subId.slice(-8)+'-'+Date.now())
      .on('postgres_changes',{event:'*',schema:'public',table:'checked_items'},payload=>{
        _lastRtEvent = Date.now();
        const row = payload.new || payload.old;
        if (!row || String(row.submission_id) !== String(_curSubId) || !_curSub) return;
        // CORREÇÃO: s\u00F3 aplica se o item_id pertence a esta lista
        const itemBelongs = (_curSub.items||[]).some(i=>String(i.id)===String(row.item_id));
        if (!itemBelongs) return;
        if (!_curSub.checkedState) _curSub.checkedState = {};
        if (!_curSub.checkedNames) _curSub.checkedNames = {};
        if (payload.eventType === 'DELETE') { _curSub.checkedState[row.item_id] = false; }
        else { _curSub.checkedState[row.item_id] = !!row.checked; _curSub.checkedNames[row.item_id] = {name:row.checked_name||'',by:row.checked_by||''}; }
        renderDetailItems();
        if (row.checked_by && row.checked_by !== CU.login) { toast(`${!!row.checked?'✅':'⬜'} ${esc(row.checked_name||row.checked_by)} ${!!row.checked?'marcou':'desmarcou'} um item`,'info'); }
      })
      .on('postgres_changes',{event:'UPDATE',schema:'public',table:'list_submissions'},payload=>{
        _lastRtEvent = Date.now();
        const row = payload.new;
        if (!row || String(row.id) !== String(_curSubId)) return;
        if (row.status === 'concluida' && _curSub) { _curSub.status = 'concluida'; toast('Lista concluída!','success'); setTimeout(()=>{closeLD(); loadAllLists().then(()=>renderTab());},1800); }
      })
      .subscribe(status=>{
        _lastRtEvent = Date.now();
        if (status === 'CHANNEL_ERROR' || status === 'TIMED_OUT') { setTimeout(()=>{ if(_curSubId) setupSubRealtime(_curSubId); },5000); }
      });
    window._rtHeartbeat = setInterval(()=>{
      if (!_curSubId || !document.getElementById('ldPanel')) { clearInterval(window._rtHeartbeat); window._rtHeartbeat=null; return; }
      if (Date.now() - _lastRtEvent > 60000) { setupSubRealtime(_curSubId); }
    },30000);
  } catch(e) {}
}

const _isMobile = /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent);
function startDetailPoll(subId) {
  if (_detailPollTimer) clearInterval(_detailPollTimer);
  _detailPollTimer = setInterval(async()=>{
    if (!document.getElementById('ldPanel')) { clearInterval(_detailPollTimer); _detailPollTimer=null; return; }
    const {data:rows} = await sb.from('checked_items').select('item_id,checked,checked_by,checked_name').eq('submission_id',subId);
    if (!rows||!_curSub) return;
    // CORREÇÃO: s\u00F3 aplica linhas cujo item_id existe nesta submission
    const validIds = new Set((_curSub.items||[]).map(i=>String(i.id)));
    let changed = false;
    rows.filter(r=>validIds.has(String(r.item_id))).forEach(r=>{
      const prev = !!(_curSub.checkedState||{})[r.item_id];
      if (prev !== !!r.checked) changed = true;
      if (!_curSub.checkedState) _curSub.checkedState = {};
      if (!_curSub.checkedNames) _curSub.checkedNames = {};
      _curSub.checkedState[r.item_id] = !!r.checked;
      _curSub.checkedNames[r.item_id] = {name:r.checked_name||'',by:r.checked_by||''};
    });
    if (changed) renderDetailItems();
  }, _isMobile ? 3000 : 8000);
}

document.addEventListener('visibilitychange',()=>{
  if (!document.hidden && _curSubId && _curSub) {
    sb.from('checked_items').select('*').eq('submission_id',_curSubId).then(({data:rows})=>{
