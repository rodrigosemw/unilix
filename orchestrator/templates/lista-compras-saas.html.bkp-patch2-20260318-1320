async function saveEditUser(login) {
  const nome=document.getElementById('euNome').value.trim();
  const avatar=document.getElementById('euAvatar').value.trim()||'👤';
  const senha=document.getElementById('euSenha').value.trim();
  const role=document.getElementById('euRole').value;
  if(!nome){toast('Digite o nome','error');return;}
  // Admin comum não pode promover a admin ou superadmin
  if(isAdminOnly() && (role==='admin'||role==='superadmin')){toast('Sem permissão para atribuir este perfil','error');return;}
  const email=document.getElementById('euEmail')?.value.trim()||null;
  const recvEls=Array.from(document.querySelectorAll('#euRecvWrap .access-chip'));
  const sends_to=recvEls.filter(e=>e.classList.contains('sel')).map(e=>e.dataset.ulogin);
  const upd={nome,avatar,role,email,sends_to,reset_requested:false,reset_temp_pass:null,reset_at:null};
  if(senha) upd.senha = await hashSenha(senha);
  await sb.from('users').update(upd).eq('login',login).eq('workspace_id',WORKSPACE_ID);

  // Atualiza allowed_users dos templates (quais listas este usuário pode preencher)
  const fillEls=Array.from(document.querySelectorAll('#euFillWrap .access-chip'));
  const selectedFillTids=new Set(fillEls.filter(e=>e.classList.contains('sel')).map(e=>e.dataset.tid));

  for(const t of templateLists){
    const wasFiller=(t.allowed_users||[]).includes(login);
    const isFiller=selectedFillTids.has(t.id);
    if(wasFiller===isFiller) continue; // nada mudou neste template

    let allowed_users=[...(t.allowed_users||[])];
    if(isFiller) allowed_users.push(login);
    else allowed_users=allowed_users.filter(x=>x!==login);

    await sb.from('template_lists').update({allowed_users}).eq('id',t.id);
    t.allowed_users=allowed_users;
  }

  // Atualiza CU se for o próprio usuário logado
  if(login===CU.login){CU.nome=nome;CU.avatar=avatar;CU.role=role;CU.sends_to=sends_to;document.getElementById('hName').textContent=nome;document.getElementById('hAvatar').textContent=avatar;}
  await loadBaseData(); await loadAllLists();
  closeModal('editUserOv');
  document.getElementById('usersListEl').innerHTML=renderUsersList();
  toast('Usuário atualizado!','success');
}

async function saveUser() {
  const login=document.getElementById('nuLogin').value.trim().toLowerCase();
  let senha=document.getElementById('nuSenha').value.trim();
  const nome=document.getElementById('nuNome').value.trim();
  const role=document.getElementById('nuRole').value;
  const avatar=document.getElementById('nuAvatar').value.trim()||'👤';
  const email=document.getElementById('nuEmail')?.value.trim()||null;
  if(!login||!senha||!nome){toast('Preencha tudo','error');return;}
  senha = await hashSenha(senha);

  if (!checkPlanLimit('users', allUsers.length)) return;

  const {error}=await sb.from('users').insert({workspace_id:WORKSPACE_ID,login,senha,nome,role,avatar,email});
  if(error){toast('Erro: login já existe?','error');return;}

  // Salva sends_to no próprio usuário e allowed_users nos templates
  const fillEls=Array.from(document.querySelectorAll('#nuFillWrap .access-chip'));
  const selectedFillTids=new Set(fillEls.filter(e=>e.classList.contains('sel')).map(e=>e.dataset.tid));
  const recvEls=Array.from(document.querySelectorAll('#nuRecvWrap .access-chip'));
  const sends_to=recvEls.filter(e=>e.classList.contains('sel')).map(e=>e.dataset.ulogin);

  // Salva sends_to no usuário recém-criado
  if(sends_to.length){
    await sb.from('users').update({sends_to}).eq('login',login).eq('workspace_id',WORKSPACE_ID);
  }

  for(const t of templateLists){
    const isFiller=selectedFillTids.has(t.id);
    if(!isFiller) continue;
    let allowed_users=[...(t.allowed_users||[])];
    if(!allowed_users.includes(login)) allowed_users.push(login);
    await sb.from('template_lists').update({allowed_users}).eq('id',t.id);
    t.allowed_users=allowed_users;
  }

  await loadBaseData();
  document.getElementById('usersListEl').innerHTML=renderUsersList();
  document.getElementById('nuLogin').value='';
  document.getElementById('nuSenha').value='';
  document.getElementById('nuNome').value='';
  // Limpa chips
  document.querySelectorAll('#nuFillWrap .access-chip,#nuRecvWrap .access-chip').forEach(c=>c.classList.remove('sel'));
  toast('Criado!','success');
}

async function deleteUser(login) {
  if(login===CU.login){toast('Não pode deletar você mesmo','error');return;}
  if (!(await customConfirm(`Deletar "${login}"? As listas enviadas por ele serão removidas.`))) return;

  // 1. Remove das submissions enviadas por este usuário (status=enviada)
  //    Cancela as listas que ele enviou e ainda estão abertas
  const {data:sentByUser}=await sb.from('list_submissions')
    .select('id').eq('workspace_id',WORKSPACE_ID).eq('submitted_by',login).eq('status','enviada');
  if(sentByUser&&sentByUser.length){
    const ids=sentByUser.map(s=>s.id);
    await sb.from('checked_items').delete().in('submission_id',ids);
    await sb.from('list_submissions').delete().in('id',ids).eq('workspace_id',WORKSPACE_ID);
  }

  // 2. Remove o login de sent_to nas submissions abertas onde ele era destinatário
  const {data:subsSentTo}=await sb.from('list_submissions')
    .select('id,sent_to').eq('workspace_id',WORKSPACE_ID).eq('status','enviada').contains('sent_to',[login]);
  for(const s of (subsSentTo||[])){
    const newSentTo=(s.sent_to||[]).filter(l=>l!==login);
    await sb.from('list_submissions').update({sent_to:newSentTo}).eq('id',s.id);
  }

  // 3. Remove o login de allowed_users e receivers dos templates
  const {data:templates}=await sb.from('template_lists')
    .select('id,allowed_users,receivers').eq('workspace_id',WORKSPACE_ID);
  for(const t of (templates||[])){
    const changed=
      (t.allowed_users||[]).includes(login)||
      (t.receivers||[]).includes(login);
    if(!changed) continue;
    await sb.from('template_lists').update({
      allowed_users:(t.allowed_users||[]).filter(l=>l!==login),
      receivers:(t.receivers||[]).filter(l=>l!==login)
    }).eq('id',t.id);
  }

  // 4. Remove notificações do usuário
  await sb.from('notifications')
    .delete().eq('workspace_id',WORKSPACE_ID).eq('to_login',login);

  // 5. Deleta o usuário
  await sb.from('users').delete().eq('login',login).eq('workspace_id',WORKSPACE_ID);

  await loadBaseData();
  document.getElementById('usersListEl').innerHTML=renderUsersList();
  toast('Usuário e dados removidos','info');
}

