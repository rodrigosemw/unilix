async function doLoginBiometric() {
  const login = (document.getElementById('loginInput')?.value||'').trim().toLowerCase();
  if (!login) { toast('Preencha o login','error'); return; }
  try {
    // Cria um desafio simples — só para confirmar presença no dispositivo
    const challenge = new Uint8Array(32);
    crypto.getRandomValues(challenge);
    await navigator.credentials.get({
      publicKey: {
        challenge,
        timeout: 60000,
        userVerification: 'required',
        rpId: location.hostname
      }
    }).catch(async ()=>{
      // Fallback: usa a API de autenticação do dispositivo via PasswordCredential
      return null;
    });
    // Se chegou aqui, usuário autenticou no dispositivo — busca dados do banco
    show('loadingOverlay');
    const {data} = await sb.from('users').select('*').eq('login',login).eq('workspace_id',WORKSPACE_ID).single();
    if (!data) { hide('loadingOverlay'); document.getElementById('loginError').style.display='block'; return; }
    CU = data;
    localStorage.setItem('lf_u_'+WORKSPACE_ID, JSON.stringify({login}));
    try { await sb.rpc('update_last_seen', {p_login: login, p_workspace_id: WORKSPACE_ID}); } catch(e){}
    await afterLogin();
  } catch(err) {
    toast('Autentica\u00E7\u00E3o cancelada','error');
  }
}

