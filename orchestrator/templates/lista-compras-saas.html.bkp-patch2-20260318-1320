// ── Cache helpers ──
function cacheSet(key, data) {
  try { localStorage.setItem(CACHE_PREFIX + key, JSON.stringify(data)); } catch(e) {}
}
function cacheGet(key) {
  try { const v = localStorage.getItem(CACHE_PREFIX + key); return v ? JSON.parse(v) : null; } catch(e) { return null; }
}
function cacheClear(key) {
  try { localStorage.removeItem(CACHE_PREFIX + key); } catch(e) {}
}

// ── Offline queue ──
function queueGet() {
  try { return JSON.parse(localStorage.getItem(QUEUE_KEY) || '[]'); } catch(e) { return []; }
}
function queueAdd(op) {
  const q = queueGet();
  q.push({ ...op, _id: Date.now() + '_' + Math.random().toString(36).slice(2), _ts: Date.now() });
  try { localStorage.setItem(QUEUE_KEY, JSON.stringify(q)); } catch(e) {}
}
function queueRemove(id) {
  const q = queueGet().filter(op => op._id !== id);
  try { localStorage.setItem(QUEUE_KEY, JSON.stringify(q)); } catch(e) {}
}

// ── Flush: executa operações pendentes ──
async function flushQueue() {
  const q = queueGet();
  if (!q.length) return;
  let failed = [];
  for (const op of q) {
    try {
      await _execQueueOp(op);
      queueRemove(op._id);
    } catch(e) {
      failed.push(op);
    }
  }
  // Recarrega dados após sync
  if (q.length > failed.length) {
    await loadBaseData();
    await loadAllLists();
    renderTab();
  }
  if (failed.length) {
    console.warn('[offline] Operações com falha:', failed.length);
  }
}

async function _execQueueOp(op) {
  const { table, action, payload, eq_field, eq_value, conflict } = op;
  let q = sb.from(table);
  if      (action === 'insert') await q.insert(payload);
  else if (action === 'update') await q.update(payload).eq(eq_field, eq_value);
  else if (action === 'delete') await q.delete().eq(eq_field, eq_value);
  else if (action === 'upsert') await q.upsert(payload, { onConflict: conflict || 'id' });
}

// ── Wrapper: faz operação se online, enfileira se offline ──
async function sbWrite({ table, action, payload, eq_field, eq_value, conflict }) {
  if (_isOnline) {
    let q = sb.from(table);
    if      (action === 'insert') return await q.insert(payload);
    else if (action === 'update') return await q.update(payload).eq(eq_field, eq_value);
    else if (action === 'delete') return await q.delete().eq(eq_field, eq_value);
    else if (action === 'upsert') return await q.upsert(payload, { onConflict: conflict || 'id' });
  } else {
    queueAdd({ table, action, payload, eq_field, eq_value, conflict });
    return { data: payload, error: null }; // otimista
  }
}

// ── Cache das leituras principais ──
async function sbReadCached(key, queryFn) {
  if (_isOnline) {
    try {
      const result = await queryFn();
      if (!result.error && result.data) {
        cacheSet(key, result.data);
      }
      return result;
    } catch(e) {
      const cached = cacheGet(key);
      return { data: cached || [], error: null };
    }
  } else {
    const cached = cacheGet(key);
    return { data: cached || [], error: null };
  }
}

