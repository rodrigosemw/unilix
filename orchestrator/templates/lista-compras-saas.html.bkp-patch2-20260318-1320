  if (!(await customConfirm(`Deletar a categoria "${cat?.nome}" e seus ${items.length} item(ns)?\nIsso n\u00E3o pode ser desfeito.`))) return;
  // Deleta itens da categoria
  if(items.length) await sb.from('items').delete().eq('category_id',catId).eq('workspace_id',WORKSPACE_ID);
  // Deleta categoria
  await sb.from('categories').delete().eq('id',catId).eq('workspace_id',WORKSPACE_ID);
  toast('Categoria deletada!','success');
  await loadBaseData();
  document.getElementById('catListEl').innerHTML=renderCatList();
}

function toggleCatSection(key) {
