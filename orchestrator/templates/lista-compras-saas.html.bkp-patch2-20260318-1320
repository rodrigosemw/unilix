function toggleAddCat(catKey) {
  const el=document.getElementById(catKey);
  const toggle=document.getElementById('toggle_'+catKey);
  if(!el) return;
  const visible=el.style.display!=='none';
  el.style.display=visible?'none':'block';
  if(toggle) toggle.textContent=visible?'▶':'▼';
}

function switchAddTab(tab, templateId) {
  const isInd = tab === 'ind';
  document.getElementById('addTabInd').style.display = isInd ? '' : 'none';
  document.getElementById('addTabCat').style.display = isInd ? 'none' : '';
  document.getElementById('tabIndBtn').style.background = isInd ? 'var(--accent)' : 'var(--surface2)';
  document.getElementById('tabIndBtn').style.color = isInd ? '#0c0f0e' : 'var(--muted)';
  document.getElementById('tabCatBtn').style.background = isInd ? 'var(--surface2)' : 'var(--accent)';
  document.getElementById('tabCatBtn').style.color = isInd ? 'var(--muted)' : '#0c0f0e';
}

async function addCategoryToTemplate(catId, templateId) {
  const tmpl = templateLists.find(t=>t.id===templateId);
  if (!tmpl) return;
  const existingItems = (tmpl.items||[]).filter(i=>!i.suggested);
  const alreadyNames = existingItems.map(i=>i.nome.toLowerCase().trim());
  const catItems = allItems.filter(i=>i.category_id===catId);
  const toAdd = catItems.filter(i=>!alreadyNames.includes(i.nome.toLowerCase().trim()));

  if (!toAdd.length) { toast('Todos os produtos desta categoria já estão na lista','info'); return; }

  // Verificar limite de itens
  if (!checkPlanLimit('items', existingItems.length + toAdd.length - 1)) return;

  const newEntries = toAdd.map(i=>({
    id: 'itm_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),
    nome: i.nome,
    category_id: i.category_id,
    unidade: i.unidade||'un',
    fornecedor: i.fornecedor||'',
    suggested: false
  }));

  const allNewItems = [...(tmpl.items||[]), ...newEntries];
  await sb.from('template_lists').update({items: allNewItems}).eq('id', templateId);
  toast(`✅ ${toAdd.length} produto${toAdd.length!==1?'s':''} adicionado${toAdd.length!==1?'s':''}!`, 'success');
  closeModal('addItemOv');
  await loadBaseData();
  await loadAllLists();
  closeLD(false, true);
  openAdminTemplate(templateId);
}

function filterCatalog(templateId) {
  const q=(document.getElementById('itemSearch')?.value||'').toLowerCase();
  const tmpl=templateLists.find(t=>t.id===templateId);
  const alreadyIn=(tmpl?.items||[]).map(ti=>ti.nome.toLowerCase().trim());
  const results=allItems.filter(i=>!q||i.nome.toLowerCase().includes(q));
  const el=document.getElementById('catResults'); if(!el) return;
  if (!results.length) {
    if (allItems.length === 0) {
      el.innerHTML=`<div style="text-align:center;padding:16px 8px">
        <div style="font-size:28px;margin-bottom:8px">📦</div>
        <div style="font-size:13px;font-weight:600;margin-bottom:6px">Catálogo vazio</div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:10px">Adicione produtos ao catálogo primeiro</div>
        <button class="btn-ghost" style="font-size:12px;padding:7px 12px;color:var(--accent);border-color:var(--accent)" onclick="closeModal('addItemOv');openNovoProduto('catalogo')">📦 Ir ao Catálogo</button>
      </div>`;
    } else {
      el.innerHTML='<p class="text-muted text-sm" style="padding:8px">Nenhum resultado para a busca</p>';
    }
    return;
  }
  el.innerHTML=results.map(i=>{
    const cat=allCategories.find(c=>c.id===i.category_id);
    const added=alreadyIn.includes(i.nome.toLowerCase().trim());
    if (added) {
      return `<div class="chip" style="margin-bottom:6px;opacity:0.5;cursor:default">
        <div class="chip-av">${cat?.emoji||'📦'}</div>
        <div style="flex:1;min-width:0"><div class="chip-name">${esc(i.nome)}</div><div class="chip-meta">${esc(cat?.nome||'')} · ${esc(i.unidade||'un')}${i.fornecedor?' · '+esc(i.fornecedor):''}</div></div>
        <span style="font-size:11px;color:var(--accent);font-weight:700;flex-shrink:0">✓ na lista</span>
      </div>`;
    }
    return `<div class="chip" style="cursor:pointer;margin-bottom:6px" onclick="addItemDirectly('${i.id}','${templateId}')">
      <div class="chip-av">${cat?.emoji||'📦'}</div>
      <div style="flex:1;min-width:0"><div class="chip-name">${esc(i.nome)}</div><div class="chip-meta">${esc(cat?.nome||'')} · ${esc(i.unidade||'un')}${i.fornecedor?' · '+esc(i.fornecedor):''}</div></div>
      <span style="font-size:20px;color:var(--accent);font-weight:300;flex-shrink:0;line-height:1;padding-left:6px">+</span>
    </div>`;
  }).join('');
}

function selectAllCatItems(catId) {
  document.querySelectorAll(`.share-item-row[data-catid="${catId}"][data-blocked="0"]`).forEach(row=>{
    row.classList.add('sel');
    row.querySelector('.sir-check').textContent='✓';
  });
}

async function addSelectedCatItems(templateId) {
  const tmpl = templateLists.find(t=>t.id===templateId);
  if(!tmpl) return;
  const selected = Array.from(document.querySelectorAll('#addItemOv .share-item-row.sel[data-blocked="0"]')).map(r=>r.dataset.iid);
  if(!selected.length){toast('Selecione ao menos um item','error');return;}
  const existingItems=(tmpl.items||[]).filter(i=>!i.suggested);
  const alreadyNames=existingItems.map(i=>i.nome.toLowerCase().trim());
  const toAdd=allItems.filter(i=>selected.includes(i.id)&&!alreadyNames.includes(i.nome.toLowerCase().trim()));
  if(!toAdd.length){toast('Todos os itens selecionados já estão na lista','info');return;}
  if(!checkPlanLimit('items',existingItems.length+toAdd.length-1)) return;
  const newEntries=toAdd.map(i=>({
    id:'itm_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),
    nome:i.nome,category_id:i.category_id,unidade:i.unidade||'un',fornecedor:i.fornecedor||'',qty_padrao:i.quantidade_padrao||1,suggested:false
  }));
  await sb.from('template_lists').update({items:[...(tmpl.items||[]),...newEntries]}).eq('id',templateId);
  toast(`✅ ${toAdd.length} item(ns) adicionado(s)!`,'success');
  closeModal('addItemOv');
  await loadBaseData();
  await loadAllLists();
  closeLD(false, true);
  openAdminTemplate(templateId);
}

async function addItemDirectly(itemId, templateId) {
  const item=allItems.find(i=>i.id===itemId); if(!item) return;
  const tmpl=templateLists.find(t=>t.id===templateId); if(!tmpl) return;
  const items=tmpl.items||[];
  const approvedItems=items.filter(i=>!i.suggested);
  if(!checkPlanLimit('items',approvedItems.length)) return;
  if(items.some(i=>i.nome.toLowerCase().trim()===item.nome.toLowerCase().trim())) {
    toast('Item já está na lista','info'); return;
  }
  const newItem={
    id:'itm_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),
    nome:item.nome, category_id:item.category_id,
    unidade:item.unidade||'un', fornecedor:item.fornecedor||'', qty_padrao:item.quantidade_padrao||1, suggested:false
  };
  // Atualiza em memória imediatamente para re-render correto
  tmpl.items=[...items,newItem];
  // Re-renderiza chips mostrando item como "na lista"
  filterCatalog(templateId);
  toast(`✅ ${item.nome} adicionado!`,'success');
  // Salva no banco (aguarda para garantir consistência ao fechar o modal)
  await sb.from('template_lists').update({items:tmpl.items}).eq('id',templateId);
}

