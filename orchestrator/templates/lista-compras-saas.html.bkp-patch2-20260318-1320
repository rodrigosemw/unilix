            : `<select class="form-input" id="eiCat"><option value="" disabled ${!item.category_id?'selected':''}>Selecione...</option>${allCategories.map(c=>`<option value="${c.id}" ${c.id===item.category_id?'selected':''}>${c.emoji} ${esc(c.nome)}</option>`).join('')}</select>`}
