async function updateItem(itemId, returnCatId) {
  const nome=document.getElementById('eiCatName').value.trim();
  if(!nome){toast('Digite o nome','error');return;}
  const oldItem=allItems.find(i=>i.id===itemId);
  const oldNome=oldItem?.nome?.toLowerCase().trim()||'';
  const eiCatEl = document.getElementById('eiCatCat');
  const newCatId = eiCatEl ? (eiCatEl.value || null) : null;
  if (!newCatId && allCategories.length > 0) { toast('Selecione uma categoria','error'); return; }
  const newUnit=document.getElementById('eiCatUnit').value.trim()||'un';
  const newSupp=document.getElementById('eiCatSupp').value.trim();
  // 1. Salva item no catálogo
  const newQtd=parseFloat(document.getElementById('eiCatQtd')?.value)||1;
  await sb.from('items').update({nome,category_id:newCatId,unidade:newUnit,fornecedor:newSupp,quantidade_padrao:newQtd}).eq('id',itemId);
  // 2. Processa atribuição de listas (add/remove/update em cada template)
  for(const tl of templateLists){
    const cb=document.getElementById(`tl_ei_${tl.id}`);
    if(!cb) continue;
    const want=cb.checked;
    const curItems=tl.items||[];
    const existIdx=curItems.findIndex(ti=>!ti.suggested&&ti.nome.toLowerCase().trim()===oldNome);
    const inList=existIdx!==-1;
    if(want&&!inList){
      const newEntry={id:'itm_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),nome,category_id:newCatId,unidade:newUnit,fornecedor:newSupp,suggested:false};
      const updated=[...curItems,newEntry];
      await sb.from('template_lists').update({items:updated}).eq('id',tl.id);
      tl.items=updated;
    } else if(!want&&inList){
      const updated=curItems.filter((_,i)=>i!==existIdx);
      await sb.from('template_lists').update({items:updated}).eq('id',tl.id);
      tl.items=updated;
    } else if(want&&inList){
      const updated=curItems.map((ti,i)=>i===existIdx?{...ti,nome,category_id:newCatId,unidade:newUnit,fornecedor:newSupp}:ti);
      await sb.from('template_lists').update({items:updated}).eq('id',tl.id);
      tl.items=updated;
    }
  }
  await loadBaseData();
  closeModal('editItemCatOv');
  if(returnCatId&&document.getElementById('catDetailItems')) document.getElementById('catDetailItems').innerHTML=renderCatDetailItems(returnCatId);
  if(document.getElementById('catListEl')) document.getElementById('catListEl').innerHTML=renderCatList();
  if(document.getElementById('itemsListEl')) document.getElementById('itemsListEl').innerHTML=renderItemsList();
  toast('Produto atualizado!','success');
}


