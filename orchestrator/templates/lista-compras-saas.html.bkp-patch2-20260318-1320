async function generatePDF(subId) {
  const {jsPDF}=window.jspdf;
  const {data:sub}=await sb.from('list_submissions').select('*').eq('id',subId).single();
  if (!sub) return;
  const doc=new jsPDF({unit:'mm',format:'a4'});
  const items=sub.items||[]; const cs=sub.checked_state||{};
  const submitter=allUsers.find(u=>u.login===sub.submitted_by);
  let y=20;
  doc.setFontSize(18);doc.setFont('helvetica','bold');doc.text(sub.titulo,20,y);y+=10;
  doc.setFontSize(10);doc.setFont('helvetica','normal');
  doc.text(`Por: ${submitter?.nome||sub.submitted_by}  |  ${fmtDate(sub.created_at)}`,20,y);y+=8;
  doc.line(20,y,190,y);y+=8;
  Object.entries(groupByCategory(items)).forEach(([catId,catItems])=>{
    const cat=allCategories.find(c=>c.id===catId);
    const catPdfName = cat?.nome || (catId==='_uncategorized'?'Sem Categoria':'Sem Categoria');
    doc.setFontSize(12);doc.setFont('helvetica','bold');doc.text(catPdfName,20,y);y+=7;
    catItems.forEach(item=>{
      const c2=cs[item.id]||{};
      doc.setFontSize(10);doc.setFont('helvetica','normal');
      doc.text(`${c2.checked?'[X]':'[ ]'} ${item.nome} — ${item.qty||1} ${item.unidade||'un'}${c2.checked&&c2.by?' ('+c2.by+')':''}`,25,y);
      y+=6;if(y>270){doc.addPage();y=20;}
    });y+=3;
  });
  doc.save(`${sub.titulo.replace(/\s+/g,'-')}.pdf`);
  toast('PDF gerado!','success');
}

