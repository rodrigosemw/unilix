async function addItemToTemplate(templateId) {
  const nome=document.getElementById('niName').value.trim();
  if (!nome) { toast('Digite o nome','error'); return; }
  const tmpl=templateLists.find(t=>t.id===templateId);
  const items=tmpl?.items||[];
  const approvedItems=items.filter(i=>!i.suggested);

  // Verificar limite
  if (!checkPlanLimit('items', approvedItems.length)) return;

  if (items.some(i=>i.nome.toLowerCase().trim()===nome.toLowerCase().trim())) {
    toast('Já existe um item com este nome na lista','error'); return;
  }
  const catVal = document.getElementById('niCat').value || null;
  if (!catVal && allCategories.length > 0) { toast('Selecione uma categoria','error'); return; }
  if (!catVal && allCategories.length === 0) { toast('Crie uma categoria primeiro','error'); closeModal('addItemOv'); openAdminCategories(); return; }
  const unidade=document.getElementById('niUnit').value.trim()||'un';
  const fornecedor=document.getElementById('niSupp').value.trim();
  const qtdPadrao=parseFloat(document.getElementById('niQtd')?.value)||1;
  // Salva no catálogo também
  const {data:savedItem} = await sb.from('items').insert({
    workspace_id:WORKSPACE_ID, nome, category_id:catVal,
    unidade, fornecedor, quantidade_padrao:qtdPadrao
  }).select().single();
  const newItem={
    id:'itm_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),
    nome, category_id:catVal, unidade, fornecedor,
    qty_padrao:qtdPadrao, suggested:false
  };
  await sb.from('template_lists').update({items:[...items,newItem]}).eq('id',templateId);
  toast('Item adicionado ao catálogo e à lista!','success');
  closeModal('addItemOv');
  await loadBaseData();
  await loadAllLists();
  closeLD(false, true);
  openAdminTemplate(templateId);
}

