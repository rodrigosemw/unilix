let _collapsedCats={};

function toggleCat(catKey) {
  _collapsedCats[catKey]=!_collapsedCats[catKey];
  const section=document.querySelector(`[data-catkey="${catKey}"]`);
  if (!section) return;
  const wrap=section.querySelector('.cat-items-wrap');
  const toggle=section.querySelector('.cat-toggle');
  if (!wrap) return;
  if (_collapsedCats[catKey]) {
    wrap.style.maxHeight=wrap.scrollHeight+'px';
    requestAnimationFrame(()=>{ wrap.style.maxHeight='0'; wrap.classList.add('collapsed'); });
    if (toggle) toggle.textContent='▶';
  } else {
    wrap.classList.remove('collapsed');
    wrap.style.maxHeight=wrap.scrollHeight+2000+'px';
    if (toggle) toggle.textContent='▼';
  }
}

function restoreCatState() {
  Object.keys(_collapsedCats).forEach(catKey=>{
    if (!_collapsedCats[catKey]) return;
    const section=document.querySelector(`[data-catkey="${catKey}"]`);
    if (!section) return;
    const wrap=section.querySelector('.cat-items-wrap');
    if (wrap) { wrap.classList.add('collapsed'); wrap.style.maxHeight='0'; }
    const toggle=section.querySelector('.cat-toggle');
    if (toggle) toggle.textContent='▶';
  });
}

