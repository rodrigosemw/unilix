<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <meta name="referrer" content="no-referrer">
  <meta http-equiv="Permissions-Policy" content="storage-access=*">
<title>ListaFácil</title>
<meta name="theme-color" content="#0c0f0e">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bcryptjs@2.4.3/dist/bcrypt.min.js" crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" crossorigin="anonymous"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,400&family=Nunito:wght@400;600;700;800&family=Playfair+Display:wght@400;700&family=JetBrains+Mono:wght@400;600&family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0c0f0e;--surface:#141918;--surface2:#1c2320;--surface3:#232b28;
  --accent:#3ecf6e;--accent-dim:#2a8f4c;--accent2:#f0a500;--danger:#e05252;
  --text:#eef2ef;--muted:#6b7d74;--border:#222e29;
  --radius:14px;
  --font-head:'Fraunces',serif;--font-body:'Space Grotesk',sans-serif;
  --font-scale:1;
  --fs-xs:  calc(10px * var(--font-scale));
  --fs-sm:  calc(11px * var(--font-scale));
  --fs-md:  calc(13px * var(--font-scale));
  --fs-base:calc(14px * var(--font-scale));
  --fs-lg:  calc(15px * var(--font-scale));
  --fs-xl:  calc(17px * var(--font-scale));
  --fs-2xl: calc(20px * var(--font-scale));
  --fs-3xl: calc(24px * var(--font-scale));
  --fs-hero:calc(34px * var(--font-scale));
}
html,body{font-size:calc(14px * var(--font-scale))}
body.theme-light{--bg:#f0f2ef;--surface:#fff;--surface2:#e8ebe6;--surface3:#dde1da;--accent:#1a9a48;--accent-dim:#137a38;--accent2:#d48800;--danger:#cc2f2f;--text:#111a12;--muted:#556a57;--border:#c5cfc4}
body.theme-ocean{--bg:#030d1a;--surface:#071628;--surface2:#0d2040;--surface3:#122850;--accent:#00c8ff;--accent-dim:#0090cc;--accent2:#00ffcc;--danger:#ff4466;--text:#d0eeff;--muted:#4a7a99;--border:#0d3055}
body.theme-sunset{--bg:#130a04;--surface:#1e1008;--surface2:#2d1810;--surface3:#3a2016;--accent:#ff6b35;--accent-dim:#cc4a1a;--accent2:#ffd166;--danger:#ff3355;--text:#fff0e0;--muted:#996644;--border:#3d200e}
body.theme-moonlight{--bg:#07090f;--surface:#0e1220;--surface2:#141a2e;--surface3:#1a2238;--accent:#c8b8ff;--accent-dim:#8a70dd;--accent2:#ffe566;--danger:#ff6688;--text:#e8e4ff;--muted:#5a5480;--border:#1e2540}
body.theme-forest{--bg:#050e07;--surface:#0b1a0e;--surface2:#102516;--surface3:#162e1c;--accent:#5dcc6a;--accent-dim:#3a9944;--accent2:#c8e84a;--danger:#ff5555;--text:#d0f0d8;--muted:#3d7048;--border:#173320}
body.theme-lavender{--bg:#100b18;--surface:#1a1228;--surface2:#221838;--surface3:#2a1e44;--accent:#dd88ff;--accent-dim:#aa44dd;--accent2:#ff99cc;--danger:#ff5577;--text:#f0e8ff;--muted:#7755aa;--border:#2e1f50}
body.theme-ember{--bg:#0f0505;--surface:#1c0a0a;--surface2:#2a1010;--surface3:#351515;--accent:#ff4444;--accent-dim:#cc2222;--accent2:#ff9900;--danger:#ff2244;--text:#ffe8e8;--muted:#884444;--border:#3d1212}
body.theme-desert{--bg:#141008;--surface:#201a0e;--surface2:#2d2418;--surface3:#382e1e;--accent:#e8aa44;--accent-dim:#b07a1a;--accent2:#ff8844;--danger:#dd4444;--text:#f8eecc;--muted:#886644;--border:#3d3018}
body.theme-arctic{--bg:#d8edf8;--surface:#eef6fc;--surface2:#cce3f2;--surface3:#b8d8ec;--accent:#0077bb;--accent-dim:#005a99;--accent2:#00bbdd;--danger:#cc2244;--text:#0a1e2e;--muted:#3a6880;--border:#a8cce0;}

/* BANNER DE UPGRADE */
.upgrade-banner{
  background:linear-gradient(135deg,#7c6fff22,#ff6b9d11);
  border:1px solid #7c6fff55;border-radius:12px;
  padding:14px 16px;margin-bottom:14px;
  display:flex;align-items:center;gap:12px;
}
.upgrade-banner-text{flex:1;font-size:var(--fs-sm);line-height:1.5;color:var(--text)}
.upgrade-banner-text strong{color:#c8b8ff}
.upgrade-banner-btn{
  background:linear-gradient(135deg,#7c6fff,#5a4fff);color:#fff;
  border:none;border-radius:8px;padding:8px 14px;font-size:var(--fs-sm);
  font-weight:700;cursor:pointer;white-space:nowrap;
  font-family:var(--font-body);
}

/* LIMITE BADGE */
.plan-limit-row{
  display:flex;align-items:center;justify-content:space-between;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:10px 14px;margin-bottom:12px;
  font-size:var(--fs-sm);
}
.plan-limit-bar{height:5px;background:var(--border);border-radius:3px;overflow:hidden;flex:1;margin:0 12px}
.plan-limit-fill{height:100%;border-radius:3px;transition:width .4s}

.settings-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border)}
.settings-row:last-child{border-bottom:none}
.settings-label{font-size:var(--fs-md);font-weight:600}
.settings-sub{font-size:var(--fs-sm);color:var(--muted);margin-top:2px}
.theme-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:10px}
.theme-btn{border-radius:10px;padding:10px 4px 8px;border:2px solid rgba(255,255,255,0.12);cursor:pointer;text-align:center;transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:5px;color:#fff;}
.theme-btn.light-btn{color:#222;border-color:rgba(0,0,0,0.12)}
.theme-btn.active{outline:3px solid var(--accent);outline-offset:2px}
.theme-btn .t-dot{width:24px;height:24px;border-radius:50%;border:2px solid rgba(255,255,255,0.3)}
.theme-btn.light-btn .t-dot{border-color:rgba(0,0,0,0.2)}
.theme-btn .t-name{font-size:9px;font-weight:700;line-height:1.2}
.font-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px}
.font-btn{border-radius:10px;padding:12px 4px 10px;border:2px solid var(--border);cursor:pointer;text-align:center;transition:all .2s;background:var(--surface2);color:var(--text);display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:4px;min-height:68px;}
.font-btn .f-letter{font-family:var(--font-body);font-weight:700;line-height:1}
.font-btn .f-name{font-size:10px;color:var(--muted);font-weight:600}
.font-btn.active{border-color:var(--accent)}
.font-btn.active .f-letter,.font-btn.active .f-name{color:var(--accent)}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overscroll-behavior:none}
body{font-family:var(--font-body);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
input,button,select,textarea{font-family:var(--font-body)}
button{cursor:pointer}
.screen{display:none!important}.screen.active{display:block!important}
#loginScreen.active{display:flex!important;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:24px}
.loading-overlay{position:fixed;inset:0;background:#0c0f0ef0;display:flex;align-items:center;justify-content:center;z-index:9999;flex-direction:column;gap:16px}
.spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes popIn{from{transform:scale(.92);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes checkPop{0%{transform:scale(1)}50%{transform:scale(1.45)}100%{transform:scale(1)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
.login-logo{width:68px;height:68px;background:var(--accent);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:32px;margin-bottom:20px;box-shadow:0 0 56px #3ecf6e44}
.login-title{font-family:var(--font-head);font-size:var(--fs-hero);font-weight:700;margin-bottom:4px;letter-spacing:-.5px}
.login-sub{color:var(--muted);font-size:var(--fs-base);margin-bottom:36px}
.login-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:28px;width:100%;max-width:360px;animation:slideUp .3s ease}
.field-label{font-size:var(--fs-xs);font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:6px;display:block}
.field-input{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:10px;padding:12px 14px;color:var(--text);font-size:var(--fs-lg);outline:none;transition:border-color .2s;margin-bottom:16px;appearance:none}
.field-input:focus{border-color:var(--accent)}
.password-wrap{position:relative;margin-bottom:16px}
.password-wrap .field-input{margin-bottom:0;padding-right:48px;width:100%}
.eye-btn{position:absolute;right:0;top:0;bottom:0;width:46px;display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;color:var(--muted);font-size:19px;transition:color .15s;-webkit-tap-highlight-color:transparent}
.eye-btn:hover{color:var(--text)}
.btn-primary{width:100%;background:var(--accent);color:#0c0f0e;border:none;border-radius:10px;padding:14px;font-size:var(--fs-lg);font-weight:700;cursor:pointer;transition:opacity .2s}
.btn-primary:hover{opacity:.9}
.login-error{color:var(--danger);font-size:var(--fs-md);margin:-8px 0 14px;display:none}
.app-header{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 18px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;gap:10px}
.header-left{display:flex;align-items:center;gap:10px;flex:1;min-width:0}
.header-avatar{width:36px;height:36px;border-radius:10px;background:var(--accent-dim);display:flex;align-items:center;justify-content:center;font-size:var(--fs-xl);flex-shrink:0;cursor:pointer}
.header-name{font-weight:600;font-size:var(--fs-base);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px}
.header-role{font-size:var(--fs-xs);color:var(--muted)}
.header-right{display:flex;align-items:center;gap:8px;flex-shrink:0}
.header-btn{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 10px;font-size:var(--fs-xl);cursor:pointer;position:relative;transition:border-color .2s}
.header-btn:hover{border-color:var(--accent)}
.notif-dot{position:absolute;top:-3px;right:-3px;width:10px;height:10px;border-radius:50%;background:var(--danger);border:2px solid var(--surface);display:none}
.notif-dot.show{display:block}
.nav-tabs{display:flex;background:var(--surface);border-bottom:1px solid var(--border);overflow-x:auto;scrollbar-width:none}
.nav-tabs::-webkit-scrollbar{display:none}
.nav-tab{flex:1;min-width:64px;padding:13px 8px 11px;text-align:center;font-size:var(--fs-sm);font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap;display:flex;flex-direction:column;align-items:center;gap:3px}
.nav-tab .ti{font-size:var(--fs-xl)}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.main-content{padding:16px;max-width:640px;margin:0 auto;padding-bottom:120px}
.sec-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:10px}
.sec-title{font-family:var(--font-head);font-size:var(--fs-2xl);font-weight:700;letter-spacing:-.3px}
.btn-new{background:var(--accent);color:#0c0f0e;border:none;border-radius:10px;padding:9px 16px;font-size:var(--fs-md);font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;white-space:nowrap}
.btn-new:hover{opacity:.9}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:10px;cursor:pointer;position:relative;overflow:hidden;transition:border-color .2s}
.card:hover{border-color:var(--accent-dim)}
.card-bar{position:absolute;left:0;top:0;bottom:0;width:3px}
.card-head{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:6px}
.card-title{font-weight:700;font-size:var(--fs-lg);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.card-meta{font-size:var(--fs-sm);color:var(--muted);display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.badge{display:inline-flex;align-items:center;gap:4px;border-radius:50px;padding:3px 10px;font-size:var(--fs-sm);font-weight:700;white-space:nowrap}
.badge-green{background:#3ecf6e18;border:1px solid #3ecf6e44;color:var(--accent)}
.badge-orange{background:#f0a50018;border:1px solid #f0a50044;color:var(--accent2)}
.badge-blue{background:#4a90d918;border:1px solid #4a90d944;color:#7ab8f5}
.badge-gray{background:var(--surface2);border:1px solid var(--border);color:var(--muted)}
.progress-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:10px}
.progress-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .4s}
.empty-state{text-align:center;padding:56px 20px;color:var(--muted);animation:fadeIn .3s}
.empty-icon{font-size:44px;margin-bottom:14px;opacity:.5}
.empty-text{font-size:var(--fs-lg);font-weight:600}
.empty-sub{font-size:var(--fs-md);margin-top:6px;opacity:.7}
.overlay{position:fixed;inset:0;background:#000000cc;z-index:2000;display:flex;align-items:flex-end;justify-content:center;animation:fadeIn .15s}
.overlay.center{align-items:center}
.modal{background:var(--surface);border:1px solid var(--border);border-top:2px solid var(--accent);border-radius:20px 20px 0 0;padding:20px 16px 48px;width:100%;max-width:520px;max-height:92vh;overflow-y:auto;animation:slideUp .2s ease;-webkit-overflow-scrolling:touch}
.modal.center-modal{border-radius:16px;animation:popIn .2s ease;margin:12px;padding:20px 16px 20px;max-height:90vh}
.modal-title{font-family:var(--font-head);font-weight:700;font-size:var(--fs-xl);margin-bottom:4px}
.modal-sub{font-size:var(--fs-sm);color:var(--muted);margin-bottom:14px}
.modal-close{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:5px 10px;font-size:var(--fs-sm);cursor:pointer;color:var(--muted);float:right;margin-top:-2px}
.modal-close:hover{color:var(--text)}
.form-group{margin-bottom:12px}
.form-label{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px;display:block}
.form-input{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:10px;padding:10px 12px;color:var(--text);font-size:var(--fs-base);outline:none;transition:border-color .2s;appearance:none}
.form-input:focus{border-color:var(--accent)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.btn-save{background:var(--accent);color:#0c0f0e;border:none;border-radius:10px;padding:12px 20px;font-size:var(--fs-base);font-weight:700;cursor:pointer;width:100%;margin-top:8px}
.btn-save:hover{opacity:.9}
.btn-danger{background:var(--danger);color:#fff;border:none;border-radius:10px;padding:10px 14px;font-size:var(--fs-sm);font-weight:600;cursor:pointer}
.btn-ghost{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:10px 14px;font-size:var(--fs-sm);font-weight:600;cursor:pointer;color:var(--text)}
.btn-ghost:hover{border-color:var(--accent)}
.btn-row{display:flex;gap:8px;margin-top:10px}
.btn-row>*{flex:1}
.divider{height:1px;background:var(--border);margin:16px 0}
.list-detail{position:fixed;inset:0;background:var(--bg);z-index:1500;display:flex;flex-direction:column;animation:fadeIn .18s}
.ld-header{background:var(--surface);border-bottom:1px solid var(--border);padding:13px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0}
.back-btn{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-size:var(--fs-md);font-weight:600;cursor:pointer;color:var(--text);display:flex;align-items:center;gap:5px;white-space:nowrap;flex-shrink:0}
.back-btn:hover{border-color:var(--accent)}
.ld-title{font-family:var(--font-head);font-weight:700;font-size:var(--fs-xl);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ld-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch}
.ld-inner{padding:14px 16px;max-width:640px;margin:0 auto;padding-bottom:100px}
.item-row{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:13px 14px;margin-bottom:7px;display:flex;align-items:center;gap:11px;transition:all .2s;position:relative}
.item-row.checked{opacity:.5}
.item-row.checked .item-name{text-decoration:line-through;color:var(--muted)}
.item-row.suggested{border-color:#f0a50055;background:#f0a50008}
.item-row.suggested::after{content:'sugerido';position:absolute;top:6px;right:10px;font-size:var(--fs-xs);font-weight:700;color:var(--accent2);text-transform:uppercase;letter-spacing:.5px}
.checkbox-wrap{width:26px;height:26px;border-radius:8px;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all .2s;background:var(--bg);user-select:none;-webkit-user-select:none}
.checkbox-wrap.checked{background:var(--accent);border-color:var(--accent);animation:checkPop .25s ease}
.checkbox-wrap.urgent{background:var(--danger);border-color:var(--danger);animation:checkPop .25s ease}
.check-icon{font-size:var(--fs-base);color:#0c0f0e;display:none}
.checkbox-wrap.checked .check-icon{display:block}
.checkbox-wrap.urgent .check-icon{display:block}
.item-row.urgent{border-color:#e0525255;background:#e052520a}
.urgent-badge{display:inline-flex;align-items:center;gap:3px;background:#e0525220;border:1px solid #e0525255;color:var(--danger);border-radius:4px;padding:1px 6px;font-size:var(--fs-xs);font-weight:700}
.fill-cb{width:28px;height:28px;border-radius:9px;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all .2s;background:var(--bg);user-select:none;-webkit-user-select:none;font-size:var(--fs-lg)}
.fill-cb.selected{background:var(--accent);border-color:var(--accent);animation:checkPop .25s ease}
.fill-cb.urgent{background:var(--danger);border-color:var(--danger);animation:checkPop .25s ease}
.fill-item.selected{opacity:.7}
.fill-item.urgent{border-color:#e0525255;background:#e052520a}
.item-info{flex:1;min-width:0}
.item-name{font-weight:600;font-size:var(--fs-base);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.item-sub{font-size:var(--fs-sm);color:var(--muted);margin-top:2px;display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.checked-by{background:var(--accent-dim);color:var(--accent);border-radius:4px;padding:1px 6px;font-size:var(--fs-xs);font-weight:700}
.unchecked-by{background:var(--surface2);color:var(--muted);border-radius:4px;padding:1px 6px;font-size:var(--fs-xs);font-weight:600}
.item-qty-badge{font-size:var(--fs-sm);font-weight:600;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:2px 8px;white-space:nowrap;flex-shrink:0}
.qty-inline{width:64px;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;padding:6px 8px;color:var(--text);font-size:var(--fs-md);text-align:center;outline:none;transition:border-color .2s;flex-shrink:0}
.qty-inline:focus{border-color:var(--accent)}
.cat-header{display:flex;align-items:center;gap:8px;margin:18px 0 8px;padding-bottom:6px;border-bottom:1px solid var(--border);cursor:pointer;user-select:none;-webkit-user-select:none}
.cat-header:active{opacity:.7}
.cat-emoji{font-size:var(--fs-lg)}
.cat-name-lbl{font-size:var(--fs-sm);font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted)}
.cat-count-lbl{font-size:var(--fs-sm);color:var(--muted);margin-left:auto}
.cat-toggle{font-size:var(--fs-sm);color:var(--muted);margin-left:6px;transition:transform .2s;display:inline-block}
.cat-items-wrap{overflow:hidden;transition:max-height .25s ease}
.cat-items-wrap.collapsed{max-height:0!important}
