  if (origem === 'catalogo') {
    openAdminItems();
  } else if (origem.startsWith('template:')) {
    const templateId = origem.split(':')[1];
    openAddItem(templateId);
  }
}

async function salvarNovoProduto() {
  const nome = document.getElementById('npNome')?.value.trim();
  const catId = document.getElementById('npCat')?.value || null;
  const unit = document.getElementById('npUnit')?.value.trim() || 'un';
  const forn = document.getElementById('npForn')?.value.trim() || '';
  const qtd = parseFloat(document.getElementById('npQtd')?.value) || 1;

  if (!nome) { toast('Digite o nome do produto','error'); return; }
  if (!catId && allCategories.length > 0) { toast('Selecione uma categoria','error'); return; }
  if (!catId && allCategories.length === 0) { toast('Crie uma categoria primeiro','error'); closeModal('novoProdutoOv'); openAdminCategories(); return; }

  const { error } = await sb.from('items').insert({
    workspace_id: WORKSPACE_ID, nome, category_id: catId,
    unidade: unit, fornecedor: forn, quantidade_padrao: qtd
  });

  if (error) {
    if (error.code === '23505') { toast('Produto já cadastrado com este nome','error'); return; }
    toast('Erro ao salvar: ' + error.message, 'error'); return;
  }

  await loadBaseData();
  toast('✅ Produto cadastrado!', 'success');

  const origem = sessionStorage.getItem('_novoProdutoOrigem') || 'catalogo';
  sessionStorage.removeItem('_novoProdutoOrigem');
  closeModal('novoProdutoOv');

  if (origem === 'catalogo') {
    openAdminItems();
  } else if (origem.startsWith('template:')) {
    const templateId = origem.split(':')[1];
    await loadAllLists();
    openAddItem(templateId);
  }
