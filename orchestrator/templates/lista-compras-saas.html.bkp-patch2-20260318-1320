let _fillState = {};
let _fillSort = false; // false = ordem original, true = A→Z

async function openUserList(templateId) {
  const tmpl=myTemplateLists.find(t=>t.id===templateId);
  if (!tmpl) return;
  const approvedItems=(tmpl.items||[]).filter(i=>!i.suggested);
  // Restaura estado salvo (se existir) para este template
  const _fillKey = 'lf_fill_'+WORKSPACE_ID+'_'+templateId+'_'+CU.login;
  try {
    const _savedFill = localStorage.getItem(_fillKey);
    _fillState = _savedFill ? JSON.parse(_savedFill) : {};
  } catch(e) { _fillState = {}; }
  _fillSort=false;
  _catSort={};
  const html=`<div class="list-detail" id="ldPanel">
