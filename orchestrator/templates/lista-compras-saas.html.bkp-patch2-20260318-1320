function switchTab(tab) {
  const prev = currentTab;
  currentTab=tab;
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.toggle('active',t.dataset.tab===tab));
  if (prev !== tab) history.pushState({nav:true, tab:tab},'');
  // Ao entrar na aba admin, recarrega dados para garantir que o onboarding
  // mostre o step correto sem precisar de F5
  if (tab === 'admin') {
    loadBaseData().then(() => renderTab());
  } else {
    renderTab();
  }
}

function renderTab() {
  const c=document.getElementById('tabContent');
  if (currentTab==='listas') isAdmin()?renderAdminListas(c):renderUserListas(c);
  else if (currentTab==='concluidas') renderConcluidas(c);
  else if (currentTab==='preencher') renderAdminPreencher(c);
  else if (currentTab==='admin') renderAdmin(c);
  if (isAdmin()) _renderPresenceWidget();
}

// Retorna lista de usuários online via presenceMap (excluindo o próprio se quiser)
function _getOnlineUsers(excludeSelf) {
  const map = window._presenceMap || {};
  const cutoff = Date.now() - 35000;
  return Object.values(map).filter(u => u.ts >= cutoff && (!excludeSelf || u.login !== CU.login));
}

