// SENHA — hash e verificação (bcrypt)
// ══════════════════════════════════════
async function hashSenha(plain) {
  const salt = await dcodeIO.bcrypt.genSalt(10);
  return await dcodeIO.bcrypt.hash(plain, salt);
}
async function verifySenha(plain, hash) {
  // Suporta senhas antigas (texto puro) durante migração
  if (!hash) return false;
  if (hash.startsWith('$2')) return await dcodeIO.bcrypt.compare(plain, hash);
  return plain === hash; // fallback texto puro (será migrado no próximo login)
}
