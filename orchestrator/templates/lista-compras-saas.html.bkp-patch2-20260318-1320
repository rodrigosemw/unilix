function submissionCard(l) {
  const items=l.items||[];
  const total=items.length;
  const checked=l._checkedCount!==undefined?l._checkedCount:Object.values(l.checked_state||{}).filter(v=>v.checked).length;
  const pct=total>0?Math.round(checked/total*100):0;
  const isSent=(l._role==='sent')||(l.submitted_by===CU?.login);
  const sender=allUsers.find(u=>u.login===l.submitted_by);
  const recipNames=(l.sent_to||[]).map(lg=>allUsers.find(u=>u.login===lg)?.nome||lg).filter(Boolean);
  const roleLabel=isSent
    ?(recipNames.length?`Para: ${recipNames.join(', ')}`:'Enviada')
    :`De: ${sender?.nome||l.submitted_by}`;
  return `<div class="card" onclick="openSubmissionDetail('${l.id}')">
    <div class="card-bar" style="background:${isSent?'var(--accent)':'var(--accent2)'}"></div>
    <div style="padding-left:8px">
      <div class="card-head">
        <span class="card-title">${esc(l.titulo)}</span>
        <div style="display:flex;gap:6px;align-items:center" onclick="event.stopPropagation()">
          ${!isSent?`<button onclick="openShareList('${l.id}')" style="background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:4px 10px;font-size:12px;cursor:pointer;color:var(--accent);font-weight:700">🔗 →</button>`:''}
          <span class="badge ${isSent?'badge-green':'badge-orange'}">${isSent?'📤 Enviada':'📥 Recebida'}</span>
        </div>
      </div>
      <div class="card-meta">
        <span>${roleLabel}</span>
        <span>${fmtTime(l.created_at)}</span>
        <span>${checked}/${total} comprados</span>
      </div>
      ${total>0?`<div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>`:''}
    </div>
  </div>`;
}

