async function confirmCreateWorkspace() {
  const name=document.getElementById('wsNewName')?.value.trim();
  const adminLogin=document.getElementById('wsNewAdmin')?.value.trim().toLowerCase();
  const adminPass=document.getElementById('wsNewPass')?.value.trim();
