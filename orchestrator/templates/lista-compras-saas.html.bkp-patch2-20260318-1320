async function deleteCompletedList(e, subId) {
  e.stopPropagation();
  if (!(await customConfirm('Apagar esta lista do histórico?'))) return;
  if(isAdmin()){
    const {error:e1}=await sb.from('checked_items').delete().eq('submission_id',subId);
    const {error:e2}=await sb.from('list_submissions').delete().eq('id',subId);
    if(e1||e2){toast('Erro ao apagar','error');return;}
    toast('Lista apagada!','success');
    await loadAllLists(); renderTab();
  } else {
    // localStorage como camada principal — n\u00E3o depende de RLS
    const key='lf_hidden_'+WORKSPACE_ID+'_'+CU.login;
    let hidden; try{hidden=JSON.parse(localStorage.getItem(key)||'[]');}catch(err){hidden=[];}
    if(!hidden.includes(subId)) hidden.push(subId);
    localStorage.setItem(key, JSON.stringify(hidden));
    // Tenta tamb\u00E9m salvar no banco (silencioso se falhar por RLS)
    try {
      const {data:sub}=await sb.from('list_submissions').select('id,hidden_by').eq('id',subId).maybeSingle();
      if(sub){
        const hidden_by=[...new Set([...(sub.hidden_by||[]),CU.login])];
        await sb.from('list_submissions').update({hidden_by}).eq('id',subId).eq('workspace_id',WORKSPACE_ID);
      }
    } catch(err){}
    toast('Removida do histórico!','success');
    // Remove imediatamente do cache local sem recarregar
    completedLists = completedLists.filter(l=>l.id!==subId);
    renderTab();
  }
}

async function clearAllCompleted() {
  if (!(await customConfirm(`Apagar TODAS as ${completedLists.length} listas conclu\u00EDdas permanentemente?\nIsso n\u00E3o pode ser desfeito.`))) return;
  const ids=completedLists.map(l=>l.id);
  if(!ids.length) return;
  await sb.from('checked_items').delete().in('submission_id',ids);
  await sb.from('list_submissions').delete().in('id',ids);
  await loadAllLists(); renderTab();
  toast('Histórico limpo!','success');
}

