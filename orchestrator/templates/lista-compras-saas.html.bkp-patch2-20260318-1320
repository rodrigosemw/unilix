      <button class="modal-close" onclick="closeModal('forgotPwOv')">✕</button>
      <div id="fpStep1">
        <h2 class="modal-title">🔑 Esqueci minha senha</h2>
        <p class="modal-sub">Digite seu login e o administrador será notificado para redefinir sua senha.</p>
        <div class="form-group">
          <label class="form-label">Login</label>
          <input class="form-input" id="fpLogin" placeholder="Seu usuário" autocapitalize="off"
            onkeydown="if(event.key==='Enter')doForgotPassword()">
        </div>
        <div id="fpErr" style="font-size:13px;color:var(--danger);margin-top:4px;display:none"></div>
        <div class="btn-row" style="margin-top:16px">
          <button class="btn-ghost" onclick="closeModal('forgotPwOv')">Cancelar</button>
          <button class="btn-save" id="fpBtn" style="margin-top:0" onclick="doForgotPassword()">Solicitar</button>
        </div>
      </div>
      <div id="fpStep2" style="display:none;text-align:center;padding:8px 0">
        <div style="font-size:48px;margin-bottom:16px">✅</div>
        <h2 class="modal-title" style="margin-bottom:8px">Solicitação enviada!</h2>
        <p id="fpDoneMsg" class="modal-sub" style="margin-bottom:24px"></p>
        <button class="btn-save" style="width:100%" onclick="closeModal('forgotPwOv')">OK</button>
      </div>
    </div>
  </div>`;
  document.getElementById('modals').innerHTML=html;
  setTimeout(()=>document.getElementById('fpLogin')?.focus(),100);
}

async function doForgotPassword() {
  const login=(document.getElementById('fpLogin')?.value||'').trim().toLowerCase();
  const errEl=document.getElementById('fpErr');
  errEl.style.display='none';
  if(!login){errEl.textContent='Digite o login.';errEl.style.display='block';return;}

  const wsId=WORKSPACE_ID||getWorkspaceFromURL()||localStorage.getItem('lf_workspace');
  if(!wsId){errEl.textContent='Workspace não identificado.';errEl.style.display='block';return;}

  const btn=document.getElementById('fpBtn');
  if(btn){btn.disabled=true;btn.textContent='Aguarde...';}

  function _showDone(msg){
    document.getElementById('fpStep1').style.display='none';
    document.getElementById('fpStep2').style.display='block';
    document.getElementById('fpDoneMsg').textContent=msg;
  }
  function _showErr(msg){
    if(btn){btn.disabled=false;btn.textContent='Solicitar';}
    errEl.textContent=msg; errEl.style.display='block';
  }

  // Buscar usuário
  const {data:user,error:eUser}=await sb.from('users')
    .select('*').eq('login',login).eq('workspace_id',wsId).single();
  if(eUser){ _showErr('Erro ao buscar: '+eUser.message); return; }
  if(!user){ _showDone('Se este login existir, o administrador será notificado.'); return; }

  // Gera e salva senha
  const tempPass='Temp'+Math.random().toString(36).slice(2,8).toUpperCase();
  const hashed=await hashSenha(tempPass);

  const {error:eUpd}=await sb.from('users').update({
    senha:hashed, reset_requested:true, reset_temp_pass:tempPass, reset_at:new Date().toISOString()
  }).eq('login',login).eq('workspace_id',wsId);
  if(eUpd){
    const {error:eUpd2}=await sb.from('users')
      .update({senha:hashed}).eq('login',login).eq('workspace_id',wsId);
    if(eUpd2){ _showErr('Erro ao salvar senha: '+eUpd2.message); return; }
  }

  // Buscar admins
  const {data:admins}=await sb.from('users')
    .select('login').eq('workspace_id',wsId).eq('role','admin');

  const admMsg='"'+(user.nome||login)+'" solicitou redefinição de senha. Senha temp: '+tempPass;
  let notifOk=0, notifFail=0, lastErr='';

  for(const adm of (admins||[])){
    if(adm.login===login) continue;
    const {error:ne}=await sb.from('notifications')
      .insert({to_login:adm.login, from_login:login, type:'password_reset', message:admMsg});
    if(ne){ notifFail++; lastErr=ne.message; console.error('[notif-fail]',ne.code,ne.message); }
    else notifOk++;
  }

  if(user.email) await _sendPasswordEmail(user.email, user.nome||login, tempPass, wsId);

  if(notifOk>0){
    _showDone('Solicitação enviada! O administrador foi notificado.');
  } else if(notifFail>0){
    _showErr('Erro ao notificar admin ('+lastErr+'). Mostre ao admin: senha temp = '+tempPass);
  } else {
    _showDone('Solicitação enviada! Verifique seu e-mail com a nova senha temporária.');
  }
}


// Envia email via Resend (através do orquestrador)
async function _sendPasswordEmail(toEmail, nome, tempPass, wsId) {
  try {
    const wsRes = await sb.from('workspaces').select('app_name').eq('id',wsId).single();
    const appName = wsRes?.data?.app_name || 'ListaFácil';
    const loginUrl = location.href;
    const html = `<div style="font-family:Arial,sans-serif;max-width:520px;margin:0 auto;background:#fff;border-radius:16px;overflow:hidden"><div style="background:linear-gradient(135deg,#5B5EF4,#00D2FF);padding:32px 40px;text-align:center"><h1 style="margin:0;color:#fff;font-size:1.5rem">🛒 ${appName}</h1></div><div style="padding:36px 40px"><h2 style="color:#111827;margin:0 0 8px">Olá, ${nome}!</h2><p style="color:#6B7280;line-height:1.7;margin:0 0 24px">Sua senha foi redefinida. Use as credenciais abaixo para acessar:</p><div style="background:#F5F7FF;border-radius:12px;padding:20px 24px;margin-bottom:24px"><p style="margin:0 0 8px;color:#6B7280;font-size:0.875rem">🔑 Nova senha temporária:</p><code style="font-size:1.25rem;font-weight:800;color:#5B5EF4;letter-spacing:2px">${tempPass}</code></div><a href="${loginUrl}" style="display:inline-block;background:linear-gradient(135deg,#5B5EF4,#00D2FF);color:#fff;text-decoration:none;padding:12px 32px;border-radius:10px;font-weight:700">Acessar o ${appName} →</a></div><div style="padding:16px 40px;border-top:1px solid #E5E7EB;text-align:center"><p style="margin:0;color:#9CA3AF;font-size:0.8rem">© 2026 Unilix.</p></div></div>`;
    const resp = await fetch('https://api.unilix.tech/enviar-email', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ to_email: toEmail, to_name: nome, subject: `🔑 Sua nova senha no ${appName}`, html })
    });
    const result = await resp.json();
    console.log('[email] resultado:', result);
    return result.ok;
  } catch(e) {
    console.error('[email] erro', e);
    return false;
  }
}
(function(){
  let startY=0,pulling=false,indicator=null;
  const THRESHOLD=72;
  function getIndicator(){
    if(!indicator){indicator=document.createElement('div');indicator.id='ptrIndicator';indicator.style.cssText='position:fixed;top:0;left:0;right:0;display:flex;align-items:center;justify-content:center;z-index:500;pointer-events:none;overflow:hidden;height:0;transition:height .2s;background:var(--surface);border-bottom:1px solid var(--border)';indicator.innerHTML='<div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted)"><div id="ptrSpinner" style="width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%"></div><span id="ptrLabel">Puxe para atualizar</span></div>';document.body.appendChild(indicator);}
    return indicator;
  }
  document.addEventListener('touchstart',e=>{const tc=document.getElementById('tabContent');if(!tc||tc.scrollTop>0)return;startY=e.touches[0].clientY;pulling=true;},{passive:true});
  document.addEventListener('touchmove',e=>{if(!pulling)return;const dist=e.touches[0].clientY-startY;if(dist<0){pulling=false;return;}const ind=getIndicator();const h=Math.min(dist*0.45,THRESHOLD);ind.style.height=h+'px';const lbl=document.getElementById('ptrLabel');if(lbl)lbl.textContent=h>=THRESHOLD?'Solte para atualizar':'Puxe para atualizar';const spin=document.getElementById('ptrSpinner');if(spin)spin.style.animation=h>=THRESHOLD?'spin .6s linear infinite':'none';},{passive:true});
  document.addEventListener('touchend',async e=>{if(!pulling)return;pulling=false;const dist=e.changedTouches[0].clientY-startY;const ind=getIndicator();if(dist>=THRESHOLD*2.2){const lbl=document.getElementById('ptrLabel');if(lbl)lbl.textContent='Atualizando...';const spin=document.getElementById('ptrSpinner');if(spin)spin.style.animation='spin .6s linear infinite';await loadBaseData();await loadAllLists();renderTab();toast('Atualizado!','success');}ind.style.height='0';},{passive:true});
})();
