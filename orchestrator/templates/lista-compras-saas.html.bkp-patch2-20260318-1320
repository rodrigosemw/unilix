          <button class="notif-approve" onclick="approveSuggestion('${n.id}','${n.ref_id}','${extra.itemId||''}')">✅ Aprovar</button>
          <button class="notif-reject" onclick="rejectSuggestionNotif('${n.id}','${n.ref_id}','${extra.itemId||''}')">✕ Rejeitar</button>
        </div>`:''}
      ${n.ref_type==='submission'&&n.type!=='item_suggested'?`
        <button class="notif-view-btn" onclick="clickNotif('${n.id}','${n.ref_id}')">Ver Lista →</button>`:''}
    </div>`;
  }).join('');
}

async function approveSuggestion(notifId,templateId,itemId) {
  const nameInput=document.getElementById(`nei_${notifId}`);
  const nome=nameInput?nameInput.value.trim():'';
  if (!nome) { toast('Digite o nome','error'); return; }
  const tmpl=templateLists.find(t=>t.id===templateId);
  if (!tmpl) { toast('Template não encontrado','error'); return; }
  const otherItems=(tmpl.items||[]).filter(i=>i.id!==itemId);
  if (otherItems.some(i=>i.nome.toLowerCase().trim()===nome.toLowerCase().trim())) { toast('Já existe item com este nome','error'); return; }
  const updatedItems=(tmpl.items||[]).map(i=>i.id!==itemId?i:{...i,nome,suggested:false});
  await sb.from('template_lists').update({items:updatedItems}).eq('id',templateId);
  await sb.from('notifications').update({read:true,acted:true}).eq('id',notifId);
  toast('Aprovado!','success');
  await loadBaseData(); await loadAllLists(); await loadNotifications();
}

async function rejectSuggestionNotif(notifId,templateId,itemId) {
  if (!(await customConfirm('Rejeitar sugestão?'))) return;
  const tmpl=templateLists.find(t=>t.id===templateId);
  if (tmpl) { await sb.from('template_lists').update({items:(tmpl.items||[]).filter(i=>i.id!==itemId)}).eq('id',templateId); }
  await sb.from('notifications').update({read:true,acted:true}).eq('id',notifId);
  toast('Rejeitada','info');
  await loadAllLists(); await loadNotifications();
}

async function clickNotif(notifId,refId) {
  await sb.from('notifications').update({read:true}).eq('id',notifId);
  toggleNotif();
  if (refId) openSubmissionDetail(refId);
