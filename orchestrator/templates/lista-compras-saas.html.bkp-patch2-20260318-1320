async function openShareList(subId) {
  const {data:sub}=await sb.from('list_submissions').select('*').eq('id',subId).single();
  if(!sub) return;
  const items=sub.items||[];
  // Busca checked_items do banco para ter estado atual
  const {data:ci}=await sb.from('checked_items').select('*').eq('submission_id',subId);
  const checkedMap={};
  (ci||[]).forEach(r=>{ checkedMap[r.item_id]={checked:r.checked,name:r.checked_name||r.checked_by}; });

  // ── Monta cadeia completa de quem já está envolvido ──────────
  // Sobe todos os ancestrais via parent_id para pegar quem preencheu originalmente
  const chainLogins=new Set();
  chainLogins.add(sub.submitted_by);
  (sub.sent_to||[]).forEach(l=>chainLogins.add(l));

  // Sobe a cadeia de pais até a raiz
  let cursor=sub;
  while(cursor.parent_id){
    const{data:parent}=await sb.from('list_submissions')
      .select('id,submitted_by,sent_to,parent_id').eq('id',cursor.parent_id).single();
    if(!parent) break;
    chainLogins.add(parent.submitted_by);
    (parent.sent_to||[]).forEach(l=>chainLogins.add(l));
    cursor=parent;
  }
  // Remove o próprio usuário atual da cadeia (ele está repassando, então está na cadeia)
  // mas NÃO remove ele do filtro — já é excluído abaixo pelo u.login!==CU.login
  chainLogins.delete(CU.login);

  const html=`<div class="overlay" id="shareOv" onclick="if(event.target===this)closeModal('shareOv')">
    <div class="modal" style="display:flex;flex-direction:column;max-height:88dvh;max-height:88vh">
      <div class="modal-fixed-head" style="padding:16px 14px 0;flex-shrink:0">
        <button class="modal-close" onclick="closeModal('shareOv')">✕</button>
        <h2 class="modal-title">🔗 Repassar Lista</h2>
        <p class="modal-sub">Escolha os destinatários e quais itens incluir.</p>
      </div>
      <div class="modal-scroll-body" style="padding:0 14px 20px">
      <label class="form-label">Para quem</label>
      <div style="display:flex;flex-wrap:wrap;margin-bottom:16px" id="shareTargetsWrap">
        ${allUsers
          .filter(u=>u.login!==CU.login)
          .map(u=>{
            const blocked=chainLogins.has(u.login);
            return `<div class="access-chip${blocked?' blocked-chain':''}"
              data-login="${u.login}"
              ${blocked?`style="opacity:.35;cursor:not-allowed;pointer-events:none" title="Já está na cadeia desta lista"`:''}
            >${u.avatar||'👤'} ${esc(u.nome)}${blocked?` <span style="font-size:9px">🚫</span>`:''}</div>`;
          }).join('')}
      </div>
      ${allUsers.filter(u=>u.login!==CU.login&&chainLogins.has(u.login)).length>0?`
        <p style="font-size:11px;color:var(--muted);margin-bottom:12px;margin-top:-8px">
          🚫 Usuários bloqueados já estão na cadeia desta lista
        </p>`:''}
      <label class="form-label">Quais itens</label>
      <div style="display:flex;gap:8px;margin-bottom:10px">
        <button class="btn-ghost" style="font-size:12px;padding:6px 12px" onclick="shareSelectAll(true)">Todos livres</button>
        <button class="btn-ghost" style="font-size:12px;padding:6px 12px" onclick="shareSelectAll(false)">Nenhum</button>
      </div>
      <div style="max-height:260px;overflow-y:auto" id="shareItemsList">
        ${items.map(item=>{
          const c2=checkedMap[item.id]||{};
          const isChecked=!!c2.checked;
          return `<div class="share-item-row ${isChecked?'blocked':'sel'}" data-iid="${item.id}" data-blocked="${isChecked?'1':'0'}">
            <div class="sir-check">${isChecked?'✅':''}</div>
            <div style="flex:1;min-width:0">
              <div class="sir-name">${esc(item.nome)}</div>
              <div class="sir-meta">${item.qty||1} ${esc(item.unidade||'un')}${isChecked?` · marcado por ${esc(c2.name||'alguém')}`:''}</div>
            </div>
          </div>`;
        }).join('')}
      </div>
      <button class="btn-save" style="margin-top:16px;margin-bottom:4px" onclick="doShareList('${subId}')">🔗 Repassar</button>
      </div>
    </div>
  </div>`;
  document.getElementById('modals').insertAdjacentHTML('beforeend',html);

  document.querySelectorAll('#shareTargetsWrap .access-chip').forEach(chip=>{
    if(chip.classList.contains('blocked-chain')) return; // bloqueado — não permite clique
    chip.addEventListener('click',()=>chip.classList.toggle('sel'));
  });
  document.querySelectorAll('.share-item-row').forEach(row=>{
    row.addEventListener('click',()=>{
      if(row.dataset.blocked==='1') return; // itens j\u00E1 marcados n\u00E3o podem ser selecionados
      row.classList.toggle('sel');
      row.querySelector('.sir-check').textContent = row.classList.contains('sel') ? '✓' : '';
    });
    // Inicializa ✓ nos selecionados
    if(row.classList.contains('sel') && row.dataset.blocked!=='1'){
      row.querySelector('.sir-check').textContent='✓';
    }
  });
}

function shareSelectAll(sel) {
  document.querySelectorAll('.share-item-row:not(.blocked)').forEach(row=>{
    row.classList.toggle('sel',sel);
    row.querySelector('.sir-check').textContent = sel ? '✓' : '';
  });
}

async function doShareList(subId) {
  const targets=Array.from(document.querySelectorAll('#shareTargetsWrap .access-chip.sel:not(.blocked-chain)')).map(el=>el.dataset.login);
  const itemIds=Array.from(document.querySelectorAll('.share-item-row.sel:not(.blocked)')).map(el=>el.dataset.iid);
  if(!targets.length){toast('Selecione ao menos um destinatário','error');return;}
  if(!itemIds.length){toast('Selecione ao menos um item','error');return;}
  const {data:sub}=await sb.from('list_submissions').select('*').eq('id',subId).single();
  if(!sub) return;
  const allItemsList=sub.items||[];
  // Busca checked_items para estado atual
  const {data:ci}=await sb.from('checked_items').select('*').eq('submission_id',subId);
  const sharedItems=allItemsList.filter(i=>itemIds.includes(i.id));
  const titulo=`${sub.titulo} (repasse de ${CU.nome})`;
  const {data:newSub,error}=await sb.from('list_submissions').insert({workspace_id:WORKSPACE_ID,template_id:sub.template_id,titulo,submitted_by:CU.login,sent_to:targets,shared_with:[],status:'enviada',items:sharedItems,checked_state:{},parent_id:subId}).select().single();
  if(error){toast('Erro ao repassar','error');return;}
  // Copia checked_items da lista m\u00E3e para a lista filha (somente itens repassados)
  const ciToInsert=(ci||[]).filter(r=>itemIds.includes(r.item_id) && r.checked).map(r=>({
    submission_id:newSub.id,item_id:r.item_id,checked:r.checked,
    checked_by:r.checked_by,checked_name:r.checked_name,updated_at:r.updated_at
  }));
  if(ciToInsert.length) await sb.from('checked_items').insert(ciToInsert);
  // NÃO atualiza shared_with da lista original — isso fazia a lista original aparecer
  // na tela dos destinatários do repasse, causando duplicação.
  // A rastreabilidade fica garantida pelo parent_id do repasse.
  for(const login of targets){
    await sb.from('notifications').insert({to_login:login,from_login:CU.login,type:'list_received',ref_id:newSub.id,ref_type:'submission',message:`${CU.nome} repassou a lista "${titulo}"`});
  }
  closeModal('shareOv'); toast('Lista repassada!','success');
  await loadAllLists(); renderTab();
}

