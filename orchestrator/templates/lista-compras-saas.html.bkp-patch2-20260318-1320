function openSuggestItem(templateId) {
  const tmpl=(myTemplateLists.find(t=>t.id===templateId)||templateLists.find(t=>t.id===templateId));
  const existingNames=(tmpl?.items||[]).map(i=>i.nome.toLowerCase().trim());
  const html=`<div class="overlay center" id="suggestOv" onclick="if(event.target===this)closeModal('suggestOv')">
    <div class="modal center-modal">
      <button class="modal-close" onclick="closeModal('suggestOv')">✕</button>
      <h2 class="modal-title">Sugerir Item</h2>
      <p class="modal-sub">O admin receber\u00E1 uma notifica\u00E7\u00E3o para aprovar.</p>
      <div class="form-group">
        <label class="form-label">Nome do Item</label>
        <input class="form-input" id="sugName" placeholder="Nome do produto" autocapitalize="words">
        <div id="sugError" style="color:var(--danger);font-size:12px;margin-top:4px;display:none"></div>
      </div>
      <div class="form-group">
        <label class="form-label">Quantidade</label>
        <div style="display:flex;gap:8px">
          <input class="form-input" id="sugQty" type="number" min="0" step="any" placeholder="0" style="flex:1">
          <input class="form-input" id="sugUnit" placeholder="un" style="width:70px">
        </div>
      </div>
      <button class="btn-save" onclick="doSuggestItem('${templateId}')">Enviar Sugest\u00E3o</button>
    </div>
  </div>`;
  document.getElementById('modals').innerHTML=html;
  document.getElementById('sugName').addEventListener('input',()=>{
    const v=document.getElementById('sugName').value.trim().toLowerCase();
    const err=document.getElementById('sugError');
    if (v&&existingNames.includes(v)) { err.textContent='Este item já existe na lista.'; err.style.display='block'; }
    else err.style.display='none';
  });
}

async function doSuggestItem(templateId) {
  const nome=document.getElementById('sugName').value.trim();
  const qty=parseFloat(document.getElementById('sugQty').value)||0;
  const unidade=document.getElementById('sugUnit').value.trim()||'un';
  if (!nome) { toast('Digite o nome','error'); return; }
  const tmpl=(myTemplateLists.find(t=>t.id===templateId)||templateLists.find(t=>t.id===templateId));
  const existingNames=(tmpl?.items||[]).map(i=>i.nome.toLowerCase().trim());
  if (existingNames.includes(nome.toLowerCase())) { toast('Já existe um item com este nome','error'); return; }
  const items=tmpl?.items||[];
  const suggId='sug_'+Date.now();
  const newItem={id:suggId,nome,unidade,fornecedor:'',category_id:null,qty,suggested:true,suggested_by:CU.login,suggested_at:new Date().toISOString()};
  await sb.from('template_lists').update({items:[...items,newItem]}).eq('id',templateId);
  const admins=allUsers.filter(u=>u.role==='admin'||u.role==='superadmin');
  for (const adm of admins) {
    await sb.from('notifications').insert({to_login:adm.login,from_login:CU.login,type:'item_suggested',ref_id:templateId,ref_type:'template',extra:JSON.stringify({itemId:suggId,nome,unidade,qty,templateTitle:tmpl?.titulo}),message:`${CU.nome} sugeriu o item "${nome}" na lista "${tmpl?.titulo}"`});
  }
  closeModal('suggestOv'); toast('Sugestão enviada!','info');
  await loadAllLists(); renderTab();
}

