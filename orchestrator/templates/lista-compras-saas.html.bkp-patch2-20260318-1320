async function loadBaseData() {
  const wsId = WORKSPACE_ID;
  const [u,c,i] = await Promise.all([
    sbReadCached('users_'+wsId,    () => sb.from('users').select('*').eq('workspace_id', wsId)),
    sbReadCached('categories_'+wsId, () => sb.from('categories').select('*').eq('workspace_id', wsId).order('ordem')),
    sbReadCached('items_'+wsId,    () => sb.from('items').select('*').eq('workspace_id', wsId).order('nome'))
  ]);
  allUsers=u.data||[]; allCategories=c.data||[]; allItems=i.data||[];
}

async function loadAllLists() {
  // ── Carrega templates ──────────────────────────────────────
  const tlRes = await sbReadCached('tpl_'+WORKSPACE_ID, () =>
    sb.from('template_lists').select('*').eq('workspace_id', WORKSPACE_ID).order('created_at'));
  templateLists = tlRes.data||[];
  myTemplateLists = isAdmin()
    ? templateLists
    : templateLists.filter(t=>(t.allowed_users||[]).includes(CU.login));

  // ── Regra de visibilidade (mesma para admin e usuário) ─────
  // Uma submission aparece para você se:
  //   (a) você a enviou (submitted_by = seu login), OU
  //   (b) você está em sent_to dela
  // shared_with NÃO determina visibilidade — apenas rastreabilidade
  //
  // Anti-duplicação: se existe um filho (parent_id = id desta lista)
  // que você também recebe/enviou → esconde o pai, mostra só o filho
  //
  // Anti-reciclagem: ignora submissions criadas antes desta conta existir

  const userCreatedAt = CU.created_at ? new Date(CU.created_at) : new Date(0);

  async function fetchVisibleSubmissions(status) {
    const [bySent, byRecv] = await Promise.all([
      // Listas que eu enviei (inclui repasses que eu criei)
      sb.from('list_submissions').select('*')
        .eq('workspace_id', WORKSPACE_ID)
        .eq('status', status)
        .eq('submitted_by', CU.login)
        .order('created_at', {ascending: false}),
      // Listas enviadas diretamente para mim
      sb.from('list_submissions').select('*')
        .eq('workspace_id', WORKSPACE_ID)
        .eq('status', status)
        .contains('sent_to', [CU.login])
        .order('created_at', {ascending: false})
    ]);

    // Une e deduplica por id, filtra reciclagem de login
    const all = [...(bySent.data||[]), ...(byRecv.data||[])]
      .filter(l => new Date(l.created_at) >= userCreatedAt);

    const byId = new Map();
    for (const l of all) {
      if (!byId.has(l.id)) byId.set(l.id, l);
    }
    const unique = [...byId.values()];

    // ── Regra anti-duplicação ──────────────────────────────
    // Se existe um filho (repasse) desta lista que também está no meu conjunto,
    // escondo o pai — mostro só o filho (a versão mais próxima de mim na cadeia).
    // Mas: só escondo o pai se eu SOU O SUBMITTED_BY do filho
    // (significa que eu repassei) OU eu estou em sent_to do filho
    // (significa que recebi o repasse diretamente).
    const parentIdsWithVisibleChild = new Set(
      unique
        .filter(l => l.parent_id && (
          l.submitted_by === CU.login ||
          (l.sent_to||[]).includes(CU.login)
        ))
        .map(l => l.parent_id)
    );

    return unique
      .filter(l => !parentIdsWithVisibleChild.has(l.id))
      .map(l => ({...l, _role: l.submitted_by === CU.login ? 'sent' : 'received'}));
  }

  pendingLists   = await fetchVisibleSubmissions('enviada');
  completedLists = await fetchVisibleSubmissions('concluida');

  // ── Enriquece com contagem de itens marcados ───────────────
  const allSubIds = [...pendingLists, ...completedLists].map(l => l.id);
  if (allSubIds.length) {
    const {data:ci} = await sb.from('checked_items')
      .select('submission_id,item_id,checked')
      .in('submission_id', allSubIds)
      .eq('checked', true);
    const ciMap = {};
    (ci||[]).forEach(r => { ciMap[r.submission_id] = (ciMap[r.submission_id]||0)+1; });
    pendingLists   = pendingLists.map(l=>({...l, _checkedCount: ciMap[l.id]||0}));
    completedLists = completedLists.map(l=>({...l, _checkedCount: ciMap[l.id]||0}));
  }
}

