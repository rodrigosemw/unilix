function toggleFillSort(templateId) {
  _fillSort = !_fillSort;
  const btn = document.getElementById('fillSortBtn');
  if(btn) btn.classList.toggle('active', _fillSort);
  const tmpl=myTemplateLists.find(t=>t.id===templateId); if(!tmpl) return;
  let approvedItems=(tmpl.items||[]).filter(i=>!i.suggested);
  if(_fillSort) {
    // Ordena itens dentro de cada categoria e também ordena as categorias A→Z
    approvedItems=[...approvedItems].sort((a,b)=>{
      const catA=allCategories.find(c=>c.id===a.category_id)?.nome||'Zzz';
      const catB=allCategories.find(c=>c.id===b.category_id)?.nome||'Zzz';
      const catCmp=catA.localeCompare(catB,'pt');
      if(catCmp!==0) return catCmp;
      return a.nome.localeCompare(b.nome,'pt');
    });
  }
  const wrap=document.getElementById('fillItemsWrap'); if(!wrap) return;
  wrap.innerHTML=renderFillItems(approvedItems, templateId);
  // Restaura estados visuais dos itens já marcados
  Object.entries(_fillState).forEach(([id,st])=>{
    if(!st) return;
    const row=document.getElementById(`fillrow_${id}`);
    const cb=document.getElementById(`fillcb_${id}`);
    if(!row||!cb) return;
    if(st===1){row.classList.add('selected');cb.classList.add('selected');cb.textContent='✓';const qi=document.getElementById('qtyinput_'+id);if(qi){qi.style.opacity='1';qi.style.pointerEvents='auto';}}
    else if(st===2){row.classList.add('urgent');cb.classList.add('urgent');cb.textContent='🔴';}
  });
}

function renderFillItems(approvedItems, templateId) {
  const byCat=groupByCategory(approvedItems);
  const cats=Object.keys(byCat);
  if (!cats.length) return emptyState('📦','Lista vazia','');
  return cats.map(catId=>{
    let catItems=byCat[catId];
    const sorted=!!_catSort[catId];
    if (sorted) catItems=[...catItems].sort((a,b)=>a.nome.localeCompare(b.nome,'pt'));
    const cat=allCategories.find(c=>c.id===catId);
    const catKey='fillcat_'+(catId==='_uncategorized'?'uncategorized':catId);
    const collapsed=_collapsedCats[catKey];
    return `<div class="cat-section" data-catkey="${catKey}">
      <div class="cat-header">
        <span class="cat-emoji" onclick="toggleCat('${catKey}')">${cat?.emoji||'📦'}</span>
        <span class="cat-name-lbl" onclick="toggleCat('${catKey}')" style="flex:1">${esc(cat?.nome||(catId==='_uncategorized'?'⚠️ Sem Categoria':'Sem Categoria'))}</span>
        <span class="cat-count-lbl" onclick="toggleCat('${catKey}')">${catItems.length}</span>
        <button onclick="toggleCatSort('${catId}')" class="sort-btn ${sorted?'active':''}" style="font-size:10px;padding:4px 8px;margin-right:4px;border-radius:6px">A→Z</button>
        <span class="cat-toggle" onclick="toggleCat('${catKey}')">${collapsed?'▶':'▼'}</span>
      </div>
      <div class="cat-items-wrap ${collapsed?'collapsed':''}" style="max-height:${collapsed?'0':'2000px'}">
      ${catItems.map(item=>{
        const st=_fillState[item.id]||0;
        const rowCls=st===1?'selected':st===2?'urgent':'';
        const cbCls=st===1?'selected':st===2?'urgent':'';
        const cbTxt=st===1?'✓':st===2?'🔴':'';
        return `<div class="item-row fill-item ${rowCls}" id="fillrow_${item.id}" onclick="cycleFillState('${item.id}','${templateId}')">
          <div class="fill-cb ${cbCls}" id="fillcb_${item.id}">${cbTxt}</div>
          <div class="item-info">
            <div class="item-name">${esc(item.nome)}</div>
            ${item.fornecedor?`<div class="item-sub">${esc(item.fornecedor)}</div>`:''}
          </div>
          <div style="display:flex;align-items:center;gap:6px;flex-shrink:0" onclick="event.stopPropagation()">
            <input type="number" min="0" step="0.01" class="qty-inline" id="qtyinput_${item.id}"
              value="${item.qty_padrao||1}"
              style="${st===0?'opacity:0.35;pointer-events:none':''}"
              oninput="_fillQty['${item.id}']=parseFloat(this.value)||0"
            />
            <span class="item-qty-badge">${esc(item.unidade||'un')}</span>
          </div>
        </div>`;
      }).join('')}
      </div>
    </div>`;
  }).join('');
}

let _catSort={}; // { catId: true/false }
function toggleCatSort(catId) {
  _catSort[catId]=!_catSort[catId];
  // Re-renderiza só o wrap de itens desta categoria
  const catKey='fillcat_'+catId;
  const section=document.querySelector(`.cat-section[data-catkey="${catKey}"]`);
  if(!section) return;
  const btn=section.querySelector('.sort-btn');
  if(btn) btn.classList.toggle('active',!!_catSort[catId]);
  const wrap=section.querySelector('.cat-items-wrap');
  if(!wrap) return;
  // Pega os itens atuais do fillItemsWrap para esta categoria
  const tmplId=document.querySelector('[data-tmpl-id]')?.dataset?.tmplId||
    document.querySelector('.suggest-btn')?.getAttribute('onclick')?.match(/'([^']+)'/)?.[1];
  // Busca itens da categoria via allItems + template
  const tmpl=myTemplateLists.find(t=>t.id===tmplId)||templateLists.find(t=>
    (t.allowed_users||[]).includes(CU.login)||isAdmin());
  // Fallback: busca via items j\u00E1 renderizados
  let catItems=Array.from(wrap.querySelectorAll('.fill-item')).map(r=>{
    const id=r.id.replace('fillrow_','');
    return {id, nome:r.querySelector('.item-name')?.textContent||'', fornecedor:r.querySelector('.item-sub')?.textContent||'', unidade:r.querySelector('.item-qty-badge')?.textContent||'un'};
  });
  if(_catSort[catId]) catItems=[...catItems].sort((a,b)=>a.nome.localeCompare(b.nome,'pt'));
  wrap.innerHTML=catItems.map(item=>`
    <div class="item-row fill-item" id="fillrow_${item.id}" onclick="cycleFillState('${item.id}','${templateId}')">
      <div class="fill-cb" id="fillcb_${item.id}"></div>
      <div class="item-info">
        <div class="item-name">${esc(item.nome)}</div>
        ${item.fornecedor?`<div class="item-sub">${esc(item.fornecedor)}</div>`:''}
      </div>
      <span class="item-qty-badge">${esc(item.unidade||'un')}</span>
    </div>`).join('');
  // Restaura estados visuais após re-render do sort
  Object.entries(_fillState).forEach(([id,st])=>{
    if(!st) return;
    const row=document.getElementById(`fillrow_${id}`);
    const cb=document.getElementById(`fillcb_${id}`);
    if(!row||!cb) return;
    if(st===1){row.classList.add('selected');cb.classList.add('selected');cb.textContent='✓';const qi=document.getElementById('qtyinput_'+id);if(qi){qi.style.opacity='1';qi.style.pointerEvents='auto';}}
    else if(st===2){row.classList.add('urgent');cb.classList.add('urgent');cb.textContent='🔴';}
  });
  // Re-bind click com templateId
  wrap.querySelectorAll('.fill-item').forEach(r=>{
    const id=r.id.replace('fillrow_','');
    r.onclick=()=>cycleFillState(id, templateId);
  });
}

function cycleFillState(itemId, templateId) {
  const cur=_fillState[itemId]||0;
  const next=(cur+1)%3;
  _fillState[itemId]=next;
  const row=document.getElementById(`fillrow_${itemId}`);
  const cb=document.getElementById(`fillcb_${itemId}`);
  if (!row||!cb) return;
  row.classList.remove('selected','urgent');
  cb.classList.remove('selected','urgent');
  if (next===1) { row.classList.add('selected'); cb.classList.add('selected'); cb.textContent='✓'; }
  else if (next===2) { row.classList.add('urgent'); cb.classList.add('urgent'); cb.textContent='🔴'; }
  else { cb.textContent=''; }
  const sel=Object.values(_fillState).filter(v=>v>0).length;
  const ctr=document.getElementById('fillCounter');
  if (ctr) ctr.textContent=`${sel} selecionado${sel!==1?'s':''}`;
  // Persistir estado no localStorage
  if (templateId) {
    const key='lf_fill_'+WORKSPACE_ID+'_'+templateId+'_'+CU.login;
    try { localStorage.setItem(key, JSON.stringify(_fillState)); } catch(e){}
  }
}

async function submitList(templateId) {
  const tmpl=myTemplateLists.find(t=>t.id===templateId);
  if (!tmpl) return;
  const approvedItems=(tmpl.items||[]).filter(i=>!i.suggested);
  const selectedItems=[];
  approvedItems.forEach(item=>{
    const state=_fillState[item.id]||0;
    const qtyVal=_fillQty[item.id]!==undefined?_fillQty[item.id]:(item.qty_padrao||1);
    if (state>0) selectedItems.push({...item, qty:qtyVal, urgent: state===2});
  });
  if (!selectedItems.length) { toast('Marque ao menos um item','error'); return; }

  // Limpa estado salvo ao enviar
  const _fillKey='lf_fill_'+WORKSPACE_ID+'_'+templateId+'_'+CU.login;
  try { localStorage.removeItem(_fillKey); } catch(e){}

  const titulo=`${tmpl.titulo} — ${new Date().toLocaleDateString('pt-BR')}`;
  // Receivers são propriedade do USUÁRIO: para quem ele sempre envia, independente do template
  const receivers=CU.sends_to||[];

  // Modo offline: enfileira e avisa
  if (!_isOnline) {
    const offlineId = 'off_'+Date.now();
    const payload = {workspace_id:WORKSPACE_ID,template_id:templateId,titulo,
      submitted_by:CU.login,status:'enviada',items:selectedItems,
      checked_state:{},sent_to:receivers};
    queueAdd({table:'list_submissions',action:'insert',payload});
    // Notificações offline também
    for (const recv of receivers) {
      queueAdd({table:'notifications',action:'insert',payload:{
        to_login:recv,from_login:CU.login,type:'list_received',
        ref_id:offlineId,ref_type:'submission',
        message:`${CU.nome} enviou a lista "${titulo}"`
      }});
    }
    _fillState={};
    closeLD();
    toast('Lista salva — será enviada ao reconectar 📡','info');
    await loadAllLists(); renderTab(); return;
  }

  // Verifica se já existe lista enviada para este template
  const {data:existing}=await sb.from('list_submissions')
    .select('*').eq('workspace_id',WORKSPACE_ID).eq('template_id',templateId).eq('status','enviada')
    .eq('submitted_by',CU.login).order('created_at',{ascending:false}).limit(1);
  if (existing&&existing.length>0) {
    const ex=existing[0];
    const existingItems=ex.items||[];
    const existingIds=new Set(existingItems.map(i=>i.id));
    const newItems=selectedItems.filter(i=>!existingIds.has(i.id));
    const updatedExisting=existingItems.map(i=>{const sel=selectedItems.find(s=>s.id===i.id);return sel?{...i,urgent:sel.urgent}:i;});
    const mergedItems=[...updatedExisting,...newItems];
    const {error:eUpd}=await sb.from('list_submissions').update({items:mergedItems,updated_at:new Date().toISOString()}).eq('id',ex.id);
    if (eUpd) { toast('Erro ao atualizar','error'); return; }
    for (const recv of receivers) {
      await sb.from('notifications').insert({to_login:recv,from_login:CU.login,type:'list_received',ref_id:ex.id,ref_type:'submission',message:`${CU.nome} atualizou a lista "${ex.titulo}"`});
    }
    _fillState={};
    closeLD(); toast(`Lista atualizada! +${newItems.length} item(ns)`,'success');
    await loadAllLists(); renderTab(); return;
  }
  const {data,error}=await sb.from('list_submissions').insert({workspace_id:WORKSPACE_ID,template_id:templateId,titulo,submitted_by:CU.login,status:'enviada',items:selectedItems,checked_state:{},sent_to:receivers}).select().single();
  if (error) { toast('Erro ao enviar','error'); return; }
  for (const recv of receivers) {
    await sb.from('notifications').insert({to_login:recv,from_login:CU.login,type:'list_received',ref_id:data.id,ref_type:'submission',message:`${CU.nome} enviou a lista "${titulo}"`});
  }
  _fillState={};
  closeLD(); toast('Lista enviada!','success');
  await loadAllLists(); renderTab();
}

