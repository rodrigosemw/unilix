function setupRealtime() {
  rtSub=sb.channel('global_rt')
    .on('postgres_changes',{event:'*',schema:'public',table:'list_submissions'},async()=>{ await loadAllLists(); renderTab(); })
    .on('postgres_changes',{event:'*',schema:'public',table:'template_lists'},async()=>{ await loadAllLists(); renderTab(); })
    .on('postgres_changes',{event:'UPDATE',schema:'public',table:'users',filter:`workspace_id=eq.${WORKSPACE_ID}`},async p=>{
      // Atualiza last_seen no cache local sem recarregar tudo
      const updated = p.new;
      if (!updated) return;
      const idx = allUsers.findIndex(u=>u.login===updated.login);
      if (idx>=0) allUsers[idx]={...allUsers[idx], last_seen: updated.last_seen};
      if (isAdmin() && currentTab==='admin') renderTab();
    })
    .subscribe();
  notifRtSub=sb.channel('notif_rt_'+CU.login)
    .on('postgres_changes',{event:'INSERT',schema:'public',table:'notifications',filter:`to_login=eq.${CU.login}`},p=>{
      toast(p.new.message,p.new.type==='item_suggested'?'info':'success');
      loadNotifications();
    }).subscribe();
}

