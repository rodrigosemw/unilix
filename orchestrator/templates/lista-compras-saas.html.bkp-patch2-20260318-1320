async function _flushPendingNotifs() {
  try {
    const key = 'lf_pending_notifs';
    const q = JSON.parse(localStorage.getItem(key)||'[]');
    if (!q.length) return;
    const remaining = [];
    for (const n of q) {
      // Só processa notificações do workspace atual
      if (n.wsId !== WORKSPACE_ID) { remaining.push(n); continue; }
      const {error} = await sb.from('notifications').insert({
        to_login: n.toLogin, from_login: n.fromLogin,
        type: n.type, message: n.message
      });
      if (error) { console.error('[flushPendingNotifs]', error); remaining.push(n); }
    }
    localStorage.setItem(key, JSON.stringify(remaining));
  } catch(e){}
}

async function afterLogin() {
  await _flushPendingNotifs(); // envia notificações pendentes criadas antes do login
  await loadBaseData();
  document.getElementById('hName').textContent=CU.nome;
  document.getElementById('hRole').innerHTML=`<span class="rt-dot"></span>${isSuperAdmin()?'Super Admin':isAdmin()?'Administrador':'Usu\u00E1rio'}`;
  document.getElementById('hAvatar').textContent=CU.avatar||'👤';
  if (isAdmin()) {
    document.querySelector('[data-tab="admin"]').style.display='';
    document.querySelector('[data-tab="preencher"]').style.display='';
  }
  const s = await loadUserSettings();
  applySettings(s);
  await loadAllLists();

  // Workspace pausado — bloqueia tudo, mostra tela de aviso
  if (getPlan() === 'paused') {
    hide('loadingOverlay'); activate('appScreen');
    document.getElementById('tabContent').innerHTML=`
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:32px">
        <div style="font-size:64px;margin-bottom:20px">\u23F8</div>
        <h2 style="font-family:var(--font-head);font-size:24px;font-weight:700;margin-bottom:12px">Workspace Pausado</h2>
        <p style="color:var(--muted);font-size:14px;max-width:280px;line-height:1.6;margin-bottom:24px">
          O acesso a este workspace est\u00E1 suspenso.<br>Entre em contato com o suporte para reativar seu plano.
        </p>
        <div style="background:var(--surface);border:1px solid var(--danger)44;border-radius:14px;padding:20px;max-width:300px;width:100%">
          <div style="font-size:13px;color:var(--muted);margin-bottom:8px">Contato</div>
          <div style="font-weight:700;font-size:15px">suporte@listafacil.app</div>
        </div>
      </div>`;
    // Desabilita toda a barra de navegação
    document.querySelectorAll('.nav-tab').forEach(t=>t.onclick=null);
    return;
  }

  setupRealtime();
  await loadNotifications();

  // Limpeza única: remove destinatários de repasse do shared_with das listas originais.
  // Isso corrige listas já existentes no banco que foram repassadas antes desta correção.
  // Roda só uma vez por sessão de admin.
  if(isAdmin()){
    const _cleanKey='lf_cleaned_shared_'+WORKSPACE_ID;
    if(!localStorage.getItem(_cleanKey)){
      try{
        // Busca todas as submissions com parent_id (repasses)
        const{data:repasses}=await sb.from('list_submissions')
          .select('parent_id,sent_to').eq('workspace_id',WORKSPACE_ID).not('parent_id','is',null);
        if(repasses&&repasses.length){
          // Agrupa: para cada lista original, quais logins foram adicionados via repasse
          const toClean={};
          repasses.forEach(r=>{
            if(!r.parent_id) return;
            if(!toClean[r.parent_id]) toClean[r.parent_id]=new Set();
            (r.sent_to||[]).forEach(l=>toClean[r.parent_id].add(l));
          });
          // Remove esses logins do shared_with das originais
          for(const[pid,logins] of Object.entries(toClean)){
            const{data:original}=await sb.from('list_submissions').select('shared_with').eq('id',pid).single();
            if(!original) continue;
            const cleaned=(original.shared_with||[]).filter(l=>!logins.has(l));
            if(cleaned.length!==(original.shared_with||[]).length){
              await sb.from('list_submissions').update({shared_with:cleaned}).eq('id',pid);
            }
          }
        }
        localStorage.setItem(_cleanKey,'1');
        // Recarrega para refletir a limpeza
        await loadAllLists(); renderTab();
      }catch(e){ /* silencioso */ }
    }
  }

  // ══ PRESENÇA: usa Supabase Realtime Broadcast (não depende de colunas do banco) ══
  // Cada cliente envia um "ping" broadcast a cada 15s para o canal de presença
  // O admin escuta esses pings e mantém um mapa local de quem está online

  window._presenceMap = {}; // { login: { nome, avatar, role, ts } }

  function broadcastMyPresence() {
    const now = new Date().toISOString();
    // Salva last_seen do próprio usuário no localStorage
    localStorage.setItem('lf_ls_'+WORKSPACE_ID+'_'+CU.login, now);
    try {
      window._presenceCh && window._presenceCh.send({
        type: 'broadcast',
        event: 'ping',
        payload: { login: CU.login, nome: CU.nome, avatar: CU.avatar||'👤', role: CU.role, ts: Date.now(), last_seen: now }
      });
    } catch(e) {}
    // Tenta atualizar no banco via RPC (contorna RLS)
    try { sb.rpc('update_last_seen', {p_login: CU.login, p_workspace_id: WORKSPACE_ID}).then(()=>{}).catch(()=>{}); } catch(e) {}
  }

  // Canal de presença compartilhado por workspace
  window._presenceCh = sb.channel('presence_' + WORKSPACE_ID, {
    config: { broadcast: { self: true } }
  })
  .on('broadcast', { event: 'ping' }, ({ payload }) => {
    if (!payload || !payload.login) return;
    window._presenceMap[payload.login] = { ...payload, ts: Date.now() };
    // Persiste last_seen no localStorage (visível para o admin neste dispositivo)
    if (payload.last_seen) {
      localStorage.setItem('lf_ls_'+WORKSPACE_ID+'_'+payload.login, payload.last_seen);
    }
    // Atualiza cache local de allUsers
    const idx = allUsers.findIndex(u => u.login === payload.login);
    if (idx >= 0) { allUsers[idx].last_seen = payload.last_seen || new Date().toISOString(); }
    // Limpa entradas antigas (> 35s sem ping)
    const cutoff = Date.now() - 35000;
    Object.keys(window._presenceMap).forEach(k => {
      if (window._presenceMap[k].ts < cutoff) delete window._presenceMap[k];
    });
    if (isAdmin()) _renderPresenceWidget();
    if (isAdmin() && currentTab === 'admin') _refreshAdminPresence();
  })
  .subscribe(status => {
    if (status === 'SUBSCRIBED') {
      broadcastMyPresence();
      window._presenceInterval = setInterval(broadcastMyPresence, 15000);
    }
  });

  // Limpa canal e interval no logout
  window._presenceCleanup = () => {
    try { sb.removeChannel(window._presenceCh); } catch(e) {}
    if (window._presenceInterval) clearInterval(window._presenceInterval);
  };
  hide('loadingOverlay'); activate('appScreen');
  renderTab();
}

