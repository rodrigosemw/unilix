function triggerConfetti() {
  for(let i=0;i<50;i++) {
    const conf = document.createElement('div');
    conf.style.cssText = "position:fixed;width:10px;height:10px;background:hsl("+Math.random()*360+",100%,70%);left:"+(50+(Math.random()*10-5))+"%;top:50%;z-index:999999;border-radius:"+(Math.random()>.5?'50%':'0')+";pointer-events:none;transform:translate(-50%,-50%)";
    document.body.appendChild(conf);
    const angle = Math.random() * Math.PI * 2;
    let velocity = 5 + Math.random() * 15;
    let x = 0, y = 0, rot = 0;
    const anim = setInterval(() => {
      x += Math.cos(angle) * velocity;
      y += Math.sin(angle) * velocity + (y*0.05);
      velocity *= 0.95;
      rot += 15;
      if (!conf.parentElement) { clearInterval(anim); return; }
      conf.style.transform = "translate(calc(-50% + "+x+"px), calc(-50% + "+y+"px)) rotate("+rot+"deg)";
      if (y > window.innerHeight/2 + 300) { clearInterval(anim); conf.remove(); }
    }, 20);
  }
}
