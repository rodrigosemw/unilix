    sb.from('list_submissions').select('*').eq('id',subId).single(),
    sb.from('checked_items').select('*').eq('submission_id', subId)
  ]);
  hide('loadingOverlay');
  if (!subRes.data) return;
  _curSubId = subId;
  _curSub = subRes.data;
  if (!_curSub.checkedState) _curSub.checkedState = {};
  if (!_curSub.checkedNames) _curSub.checkedNames = {};
  // CORREÇÃO: s\u00F3 aplica checked_items cujo item_id pertence a esta lista
  const validItemIds = new Set((_curSub.items||[]).map(i=>String(i.id)));
  (checksRes.data||[]).filter(r=>validItemIds.has(String(r.item_id))).forEach(r => {
    _curSub.checkedState[r.item_id] = !!r.checked;
    _curSub.checkedNames[r.item_id] = { name: r.checked_name||'', by: r.checked_by||'' };
  });
  const isCompleted = _curSub.status === 'concluida';
