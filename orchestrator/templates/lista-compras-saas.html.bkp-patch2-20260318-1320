async function doChangePassword() {
  const login = (document.getElementById('cpLogin')?.value||'').trim().toLowerCase();
  const oldPass = document.getElementById('cpOldPass')?.value||'';
  const newPass = document.getElementById('cpNewPass')?.value||'';
  const confPass = document.getElementById('cpConfPass')?.value||'';
  const errEl = document.getElementById('cpError');
  errEl.style.display='none';

  if (!login||!oldPass||!newPass||!confPass) { errEl.textContent='Preencha todos os campos.'; errEl.style.display='block'; return; }
  if (newPass.length < 6) { errEl.textContent='A nova senha deve ter pelo menos 6 caracteres.'; errEl.style.display='block'; return; }
  if (newPass !== confPass) { errEl.textContent='As senhas n\u00E3o coincidem.'; errEl.style.display='block'; return; }

  const btn = document.querySelector('#changePwOv .btn-save');
  if(btn){btn.disabled=true;btn.textContent='Salvando...';}

  const {data:user} = await sb.from('users').select('*').eq('login',login).eq('workspace_id',WORKSPACE_ID).single();
  if (!user) { errEl.textContent='Usu\u00E1rio n\u00E3o encontrado.'; errEl.style.display='block'; if(btn){btn.disabled=false;btn.textContent='Salvar Nova Senha';} return; }

  const ok = await verifySenha(oldPass, user.senha);
  if (!ok) { errEl.textContent='Senha atual incorreta.'; errEl.style.display='block'; if(btn){btn.disabled=false;btn.textContent='Salvar Nova Senha';} return; }

  // Salva nova senha sempre com hash bcrypt
  const hashed = await hashSenha(newPass);
  const {error} = await sb.from('users').update({
    senha: hashed, reset_requested: false, reset_temp_pass: null, reset_at: null
  }).eq('login',login).eq('workspace_id',WORKSPACE_ID);
  if (error) { errEl.textContent='Erro ao salvar. Tente novamente.'; errEl.style.display='block'; if(btn){btn.disabled=false;btn.textContent='Salvar Nova Senha';} return; }

  // Remove o modal diretamente (sem history.back()) para não restaurar sessão anterior
  const ovEl = document.getElementById('changePwOv');
  if (ovEl) { ovEl.removeAttribute('data-has-hist'); ovEl.remove(); }

  // Faz login do usuário que acabou de trocar a senha
  user.senha = hashed;
  CU = user;
  localStorage.setItem('lf_u_'+WORKSPACE_ID, JSON.stringify({login}));
  show('loadingOverlay');
  try { await sb.rpc('update_last_seen', {p_login: login, p_workspace_id: WORKSPACE_ID}); } catch(e){}
  await afterLogin();
  toast('✅ Senha alterada com sucesso!','success');
}

async function doLogout() {
