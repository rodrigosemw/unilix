function renderListCheckboxes(prefix, matchNome) {
  if(!templateLists.length) return '<p style="font-size:12px;color:var(--muted);font-style:italic">Nenhuma lista criada ainda.</p>';
  const lowerNome = matchNome ? matchNome.toLowerCase().trim() : null;
  return templateLists.map(tl=>{
    const inList = lowerNome ? (tl.items||[]).some(ti=>!ti.suggested&&ti.nome.toLowerCase().trim()===lowerNome) : false;
    return `<label style="display:flex;align-items:center;gap:8px;cursor:pointer;padding:8px 10px;border-radius:8px;background:${inList?'var(--accent)18':'var(--surface2)'};margin-bottom:4px;border:1px solid ${inList?'var(--accent)':'var(--border)'}">
      <input type="checkbox" id="${prefix}_${tl.id}" ${inList?'checked':''} style="width:16px;height:16px;cursor:pointer;accent-color:var(--accent);flex-shrink:0">
      <span style="font-size:13px;font-weight:600;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${tl.emoji||'📋'} ${esc(tl.titulo)}</span>
    </label>`;
  }).join('');
}

async function applyListAssignmentsNew(prefix, nome, categoryId, unidade, fornecedor) {
  for(const tl of templateLists) {
    const cb=document.getElementById(`${prefix}_${tl.id}`);
    if(!cb||!cb.checked) continue;
    const curItems=tl.items||[];
    if(curItems.some(ti=>!ti.suggested&&ti.nome.toLowerCase().trim()===nome.toLowerCase().trim())) continue;
    const newEntry={id:'itm_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),nome,category_id:categoryId||null,unidade:unidade||'un',fornecedor:fornecedor||'',suggested:false};
    const updated=[...curItems,newEntry];
    await sb.from('template_lists').update({items:updated}).eq('id',tl.id);
    tl.items=updated;
  }
}

