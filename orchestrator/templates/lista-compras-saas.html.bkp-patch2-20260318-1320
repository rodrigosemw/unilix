async function saveEditTemplateItem() {
  const templateId=document.getElementById('eiTemplateId').value;
  const itemId=document.getElementById('eiItemId').value;
  const nome=document.getElementById('eiName').value.trim();
  if (!nome) { toast('Digite o nome','error'); return; }
  const tmpl=templateLists.find(t=>t.id===templateId);
  const items=tmpl?.items||[];
  // S\u00F3 bloqueia se OUTRO item (id diferente) tiver exatamente o mesmo nome
  const conflict=items.some(i=>String(i.id)!==String(itemId)&&i.nome.toLowerCase().trim()===nome.toLowerCase().trim());
  if (conflict) { toast('Já existe outro item com este nome','error'); return; }
  const newCatId = document.getElementById('eiCat').value || null;
  if (!newCatId && allCategories.length > 0) { toast('Selecione uma categoria','error'); return; }
  if (!newCatId && allCategories.length === 0) { toast('Crie uma categoria primeiro','error'); return; }
  const updatedItems=items.map(i=>String(i.id)!==String(itemId)?i:{...i,nome,category_id:newCatId,unidade:document.getElementById('eiUnit').value.trim()||'un',fornecedor:document.getElementById('eiSupp').value.trim(),qty_padrao:parseFloat(document.getElementById('eiQtd').value)||1,suggested:false});
  await sb.from('template_lists').update({items:updatedItems}).eq('id',templateId);
  closeModal('eiOv'); toast('Salvo!','success');
  await loadBaseData();
  await loadAllLists();
  closeLD(false, true); openAdminTemplate(templateId);
}

async function removeTemplateItem(templateId,itemId) {
  if (!(await customConfirm('Remover item da lista?'))) return;
  const tmpl=templateLists.find(t=>t.id===templateId);
  const updatedItems=(tmpl?.items||[]).filter(i=>i.id!==itemId);
  await sb.from('template_lists').update({items:updatedItems}).eq('id',templateId);
  toast('Removido','info');
  await loadBaseData();
  await loadAllLists();
  closeLD(false, true); openAdminTemplate(templateId);
}

async function rejectSuggestion(templateId,itemId) {
  if (!(await customConfirm('Rejeitar sugestão?'))) return;
  const tmpl=templateLists.find(t=>t.id===templateId);
  const updatedItems=(tmpl?.items||[]).filter(i=>i.id!==itemId);
  await sb.from('template_lists').update({items:updatedItems}).eq('id',templateId);
  toast('Sugestão rejeitada','info');
  await loadAllLists();
  closeLD(false, true); openAdminTemplate(templateId);
}

