<script>

// ══════════════════════════════════════════════════════════════
// SISTEMA OFFLINE — cache local + fila de sync
// ══════════════════════════════════════════════════════════════

// ── Chaves de cache no localStorage ──
const CACHE_PREFIX     = 'lf_cache_';
const QUEUE_KEY        = 'lf_offline_queue';
const CACHE_TIMESTAMP  = 'lf_cache_ts';

// ── Estado online ──
let _isOnline = navigator.onLine;

function setOnlineStatus(online) {
  _isOnline = online;
  const bar = document.getElementById('offlineBar');
  if (!bar) return;
  if (online) {
    bar.className = 'offline-bar syncing show';
    document.getElementById('offlineBarIcon').textContent = '🔄';
    document.getElementById('offlineBarMsg').textContent  = 'Reconectado — sincronizando...';
    flushQueue().then(() => {
      bar.className = 'offline-bar synced show';
      document.getElementById('offlineBarIcon').textContent = '✅';
      document.getElementById('offlineBarMsg').textContent  = 'Sincronizado!';
      setTimeout(() => { bar.className = 'offline-bar'; }, 2500);
    });
  } else {
    bar.className = 'offline-bar show';
    document.getElementById('offlineBarIcon').textContent = '📡';
    document.getElementById('offlineBarMsg').textContent  = 'Sem conexão — salvando localmente';
